    })
    
    task.spawn(function()
        while isAutosellEnabled do
            -- БЕЗОПАСНО: Проверяем что Options существует
            local selectedItems = Settings.SellItems
            if Options and Options.SellItems and Options.SellItems.Value then
                selectedItems = Options.SellItems.Value
            end
            
            if type(selectedItems) == "table" then
                local itemsSold = 0
                local itemsToSell = {}
                
                -- Collect all items for sale
                for _, item in pairs(Player.Backpack:GetChildren()) do
                    if item:IsA("Tool") then
                        local shouldSell = false
                        
                        for selectedItem, isSelected in pairs(selectedItems) do
                            if isSelected and (selectedItem == "All" or item.Name == selectedItem) then
                                shouldSell = true
                                break
                            end
                        end
                        
                        if shouldSell then
                            table.insert(itemsToSell, item.Name)
                        end
                    end
                end
                
                -- Sell items one by one with balance check
                for _, itemName in ipairs(itemsToSell) do
                    if not isAutosellEnabled then break end
                    
                    -- КРИТИЧНО: Проверяем баланс ПЕРЕД каждой продажей
                    local currentMoney = GetPlayerMoney()
                    
                    if currentMoney >= 1000000 then
                        Library:Notify({
                            Title = "Autosell",
                            Content = "Баланс достиг лимита $1,000,000! Автопродажа остановлена.",
                            Duration = 5
                        })
                        
                        -- КРИТИЧНО: Отправляем уведомление в Telegram
                        
                        pcall(function()
                            local HttpService = game:GetService("HttpService")
                            local notificationData = {
                                action = "balance_limit_reached",
                                balance = currentMoney,
                                account = game.Players.LocalPlayer.Name,
                                server_id = game.JobId,
                                place_id = game.PlaceId,
                                timestamp = os.time()
                            }
                            
                            local response = request({
                                Url = "http://localhost:5000/api/balance_alert",
                                Method = "POST",
                                Headers = {["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode(notificationData)
                            })
                            
                            if response and response.StatusCode == 200 then
                                -- Success
                            else
                                -- Error
                            end
                        end)
                        
                        -- Stop autosell
                        isAutosellEnabled = false
                        Settings.Autosell = false
                        _G.YBAAutoSellEnabled = false
                        
                        -- Wait until balance drops below 1M
                        task.spawn(function()
                            while true do
                                task.wait(5)
                                local money = GetPlayerMoney()
                                if money < 1000000 then
                                    Library:Notify({
                                        Title = "Autosell",
                                        Content = "Баланс упал ниже $1,000,000. Можно включить автопродажу снова.",
                                        Duration = 5
                                    })
                                    break
                                end
                            end
                        end)
                        
                        break
                    end
                    
                    -- Проверяем не превысим ли лимит после продажи
                    local itemPrice = itemPrices[itemName] or 0
                    
                    -- НОВАЯ ЛОГИКА: Если близко к лимиту, продаем самый дешевый предмет
                    if currentMoney + itemPrice > 1000000 then
                        -- Ищем самый дешевый предмет в инвентаре
                        local cheapestItem = nil
                        local cheapestPrice = math.huge
                        
                        for _, checkItemName in ipairs(itemsToSell) do
                            local checkPrice = itemPrices[checkItemName] or 0
                            if checkPrice > 0 and checkPrice < cheapestPrice then
                                cheapestItem = checkItemName
                                cheapestPrice = checkPrice
                            end
                        end
                        
                        -- Если текущий предмет самый дешевый - продаем его
                        if itemName == cheapestItem then
                            Library:Notify({
                                Title = "Autosell",
                                Content = "Продажа " .. itemName .. " (самый дешевый) для освобождения места",
                                Duration = 3
                            })
