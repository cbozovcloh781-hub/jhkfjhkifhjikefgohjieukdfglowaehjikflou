local function UpdatePlayerlistCheaterTags()
    if cheaterViewThread then
        cheaterViewEnabled = false
        task.wait(0.1)
        cheaterViewThread = nil
    end
    
    cheaterViewEnabled = true
    cheaterViewThread = task.spawn(function()
        while cheaterViewEnabled do
            pcall(function()
                local playerGui = Player.PlayerGui
                local hud = playerGui:FindFirstChild("HUD")
                if hud then
                    local playerlist = hud:FindFirstChild("Playerlist")
                    if playerlist then
                        if playerlist.Size.Y.Scale ~= 0.7 then
                            playerlist.Size = UDim2.new(playerlist.Size.X.Scale, playerlist.Size.X.Offset, 0.7, 0)
                        end
                        
                        for _, playerFrame in pairs(playerlist:GetChildren()) do
                            if playerFrame:IsA("Frame") or playerFrame:IsA("GuiObject") then
                                local playerNameLabel = playerFrame:FindFirstChild("PlayerName")
                                if playerNameLabel and playerNameLabel:IsA("TextLabel") then
                                    local playerName = playerNameLabel.Text:gsub("%[CHEATER%] ", "")
                                    local targetPlayer = Players:FindFirstChild(playerName)
                                    
                                    local isCheater = false
                                    if targetPlayer and detectedCheaters[targetPlayer.UserId] then
                                        isCheater = true
                                    end
                                    
                                    local currentText = playerNameLabel.Text
                                    local hasCheaterTag = currentText:find("%[CHEATER%]")
                                    
                                    if isCheater and not hasCheaterTag then
                                        playerNameLabel.Text = "[CHEATER] " .. playerName
                                        playerNameLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                                    elseif not isCheater and hasCheaterTag then
                                        playerNameLabel.Text = playerName
                                        playerNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait(0.5)
        end
        cheaterViewThread = nil
    end)
end

local function ClearAllCheaterTags()
    pcall(function()
        local playerGui = Player.PlayerGui
        local hud = playerGui:FindFirstChild("HUD")
        if hud then
            local playerlist = hud:FindFirstChild("Playerlist")
            if playerlist then
                for _, playerFrame in pairs(playerlist:GetChildren()) do
                    if playerFrame:IsA("Frame") or playerFrame:IsA("GuiObject") then
                        local playerNameLabel = playerFrame:FindFirstChild("PlayerName")
                        if playerNameLabel and playerNameLabel:IsA("TextLabel") then
                            local playerName = playerNameLabel.Text:gsub("%[CHEATER%] ", "")
                            playerNameLabel.Text = playerName
                            playerNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                        end
                    end
                end
            end
        end
    end)
end

VisualsRight:AddToggle({
    Title = "Show Cheaters",
    Default = Settings.CheaterViewEnabled or false,
    Callback = function(Value)
        cheaterViewEnabled = Value
        Settings.CheaterViewEnabled = Value
        SaveConfigToServer()
        
        if Value then
            pcall(function()
                local playerGui = game:GetService("Players").LocalPlayer.PlayerGui
                local hud = playerGui:FindFirstChild("HUD")
                if hud then
                    local playerlist = hud:FindFirstChild("Playerlist")
                    if playerlist then
                        playerlist.Size = UDim2.new(playerlist.Size.X.Scale, playerlist.Size.X.Offset, 0.7, 0)
                    end
                end
            end)
            
            UpdatePlayerlistCheaterTags()
            
            if cheaterDetectionThread then
                pcall(function() task.cancel(cheaterDetectionThread) end)
            end
            
            cheaterDetectionThread = task.spawn(function()
                while cheaterViewEnabled do
                    local currentTime = tick()
                    for _, player in pairs(Players:GetPlayers()) do
                        if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                            local currentPos = player.Character.HumanoidRootPart.Position
                            if playerPositions[player.UserId] then
                                local lastPos = playerPositions[player.UserId].Position
                                local lastTime = playerPositions[player.UserId].Time
                                local timeDiff = currentTime - lastTime
                                if timeDiff > 0.5 and timeDiff < 2 then
                                    local distance = (currentPos - lastPos).Magnitude
                                    local speed = distance / timeDiff
                                    if speed > 400 then
                                        if not detectedCheaters[player.UserId] then
                                            detectedCheaters[player.UserId] = true
                                        end
                                        cheaterTimers[player.UserId] = currentTime
                                    end
                                end
                            end
                            playerPositions[player.UserId] = {Position = currentPos, Time = tick()}
                        end
                    end
                    for userId, lastViolation in pairs(cheaterTimers) do
                        if currentTime - lastViolation >= 60 then
                            detectedCheaters[userId] = nil
                            cheaterTimers[userId] = nil
                        end
                    end
                    task.wait(0.5)
                end
                cheaterDetectionThread = nil
            end)
        else
            ClearAllCheaterTags()
            pcall(function()
                local playerGui = game:GetService("Players").LocalPlayer.PlayerGui
                local hud = playerGui:FindFirstChild("HUD")
                if hud then
                    local playerlist = hud:FindFirstChild("Playerlist")
                    if playerlist then
                        playerlist.Size = UDim2.new(playerlist.Size.X.Scale, playerlist.Size.X.Offset, playerlist.Size.Y.Scale, playerlist.Size.Y.Offset)
                    end
                end
            end)
            detectedCheaters = {}
            cheaterTimers = {}
            playerPositions = {}
            if cheaterViewThread then
                pcall(function() task.cancel(cheaterViewThread) end)
                cheaterViewThread = nil
            end
            if cheaterDetectionThread then
                pcall(function() task.cancel(cheaterDetectionThread) end)
                cheaterDetectionThread = nil
            end
        end
    end
})

