local function UpdateESP(player)
    if not ESPSettings.Enabled then return end
    
    local esp = Drawings.ESP[player]
    if not esp then return end
    
    local character = player.Character
    if not character then HideESP(player) return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid or humanoid.Health <= 0 then HideESP(player) return end
    
    local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
    local distance = (rootPart.Position - Camera.CFrame.Position).Magnitude
    if not onScreen or distance > ESPSettings.MaxDistance or pos.Z <= 0 then HideESP(player) return end
    if ESPSettings.TeamCheck and player.Team == LocalPlayer.Team and not ESPSettings.ShowTeam then HideESP(player) return end
    local size = character:GetExtentsSize() local cf = rootPart.CFrame
    local top = Camera:WorldToViewportPoint((cf * CFrame.new(0, size.Y/2, 0)).Position) local bottom = Camera:WorldToViewportPoint((cf * CFrame.new(0, -size.Y/2, 0)).Position)
    local screenSize = bottom.Y - top.Y local boxWidth = screenSize * 0.65 local boxPosition = Vector2.new(top.X - boxWidth/2, top.Y) local boxSize = Vector2.new(boxWidth, screenSize)
    for _, obj in pairs(esp.Box) do obj.Visible = false end
    if ESPSettings.BoxESP then
        if ESPSettings.BoxStyle == "Corner" then
            local cornerSize = boxWidth * 0.2
            esp.Box.TopLeft.From = boxPosition esp.Box.TopLeft.To = boxPosition + Vector2.new(cornerSize, 0) esp.Box.TopLeft.Visible = true
            esp.Box.TopRight.From = boxPosition + Vector2.new(boxSize.X, 0) esp.Box.TopRight.To = boxPosition + Vector2.new(boxSize.X - cornerSize, 0) esp.Box.TopRight.Visible = true
            esp.Box.BottomLeft.From = boxPosition + Vector2.new(0, boxSize.Y) esp.Box.BottomLeft.To = boxPosition + Vector2.new(cornerSize, boxSize.Y) esp.Box.BottomLeft.Visible = true
            esp.Box.BottomRight.From = boxPosition + Vector2.new(boxSize.X, boxSize.Y) esp.Box.BottomRight.To = boxPosition + Vector2.new(boxSize.X - cornerSize, boxSize.Y) esp.Box.BottomRight.Visible = true
            esp.Box.Left.From = boxPosition esp.Box.Left.To = boxPosition + Vector2.new(0, cornerSize) esp.Box.Left.Visible = true
            esp.Box.Right.From = boxPosition + Vector2.new(boxSize.X, 0) esp.Box.Right.To = boxPosition + Vector2.new(boxSize.X, cornerSize) esp.Box.Right.Visible = true
            esp.Box.Top.From = boxPosition + Vector2.new(0, boxSize.Y) esp.Box.Top.To = boxPosition + Vector2.new(0, boxSize.Y - cornerSize) esp.Box.Top.Visible = true
            esp.Box.Bottom.From = boxPosition + Vector2.new(boxSize.X, boxSize.Y) esp.Box.Bottom.To = boxPosition + Vector2.new(boxSize.X, boxSize.Y - cornerSize) esp.Box.Bottom.Visible = true
            for _, line in pairs(esp.Box) do line.Color = GetPlayerColor(player, "box") end
        else
            esp.Box.Left.From = boxPosition esp.Box.Left.To = boxPosition + Vector2.new(0, boxSize.Y) esp.Box.Left.Visible = true
            esp.Box.Right.From = boxPosition + Vector2.new(boxSize.X, 0) esp.Box.Right.To = boxPosition + Vector2.new(boxSize.X, boxSize.Y) esp.Box.Right.Visible = true
            esp.Box.Top.From = boxPosition esp.Box.Top.To = boxPosition + Vector2.new(boxSize.X, 0) esp.Box.Top.Visible = true
            esp.Box.Bottom.From = boxPosition + Vector2.new(0, boxSize.Y) esp.Box.Bottom.To = boxPosition + Vector2.new(boxSize.X, boxSize.Y) esp.Box.Bottom.Visible = true
            local boxColor = GetPlayerColor(player, "box") esp.Box.Left.Color = boxColor esp.Box.Right.Color = boxColor esp.Box.Top.Color = boxColor esp.Box.Bottom.Color = boxColor
        end
    end
    if ESPSettings.TracerESP then esp.Tracer.From = GetTracerOrigin() esp.Tracer.To = Vector2.new(pos.X, pos.Y) esp.Tracer.Color = GetPlayerColor(player, "tracer") esp.Tracer.Visible = true else esp.Tracer.Visible = false end
    if ESPSettings.HealthESP then
        local health = humanoid.Health local maxHealth = humanoid.MaxHealth local healthPercent = health/maxHealth local barHeight = screenSize * 0.8 local barWidth = 4 local barPos = Vector2.new(boxPosition.X - barWidth - 2, boxPosition.Y + (screenSize - barHeight)/2)
        esp.HealthBar.Outline.Size = Vector2.new(barWidth, barHeight) esp.HealthBar.Outline.Position = barPos esp.HealthBar.Outline.Visible = true esp.HealthBar.Fill.Size = Vector2.new(barWidth - 2, barHeight * healthPercent) esp.HealthBar.Fill.Position = Vector2.new(barPos.X + 1, barPos.Y + barHeight * (1-healthPercent)) esp.HealthBar.Fill.Color = Color3.fromRGB(255 - (255 * healthPercent), 255 * healthPercent, 0) esp.HealthBar.Fill.Visible = true
        if ESPSettings.HealthStyle == "Both" or ESPSettings.HealthStyle == "Text" then esp.HealthBar.Text.Text = math.floor(health) .. "HP" esp.HealthBar.Text.Position = Vector2.new(barPos.X + barWidth + 2, barPos.Y + barHeight/2) esp.HealthBar.Text.Visible = true else esp.HealthBar.Text.Visible = false end
    else for _, obj in pairs(esp.HealthBar) do obj.Visible = false end end
    if ESPSettings.NameESP then 
        -- НОВОЕ: Добавляем метку [CHEATER] для читеров
        local nameText = player.DisplayName
        if detectedCheaters[player.UserId] then
            nameText = "[CHEATER] " .. nameText
        end
        esp.Info.Name.Text = nameText
        esp.Info.Name.Position = Vector2.new(boxPosition.X + boxWidth/2, boxPosition.Y - 20) 
        esp.Info.Name.Color = GetPlayerColor(player, "name") 
        esp.Info.Name.Visible = true 
    else 
        esp.Info.Name.Visible = false 
    end
    local highlight = Highlights[player] 
    if highlight and ESPSettings.ChamsEnabled and character then 
        highlight.Parent = character 
        -- НОВОЕ: Оранжевый цвет для читеров
        if detectedCheaters[player.UserId] then
            highlight.FillColor = Color3.fromRGB(255, 165, 0)
            highlight.OutlineColor = Color3.fromRGB(255, 100, 0)
        else
            highlight.FillColor = ESPSettings.ChamsFillColor
            highlight.OutlineColor = ESPSettings.ChamsOutlineColor
        end
        highlight.FillTransparency = ESPSettings.ChamsTransparency 
        highlight.OutlineTransparency = ESPSettings.ChamsOutlineTransparency 
        highlight.Enabled = true 
    elseif highlight then 
        highlight.Enabled = false 
    end
    local skeleton = Drawings.Skeleton[player]
    if ESPSettings.SkeletonESP and skeleton then
        local head = character:FindFirstChild("Head")
        local upperTorso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        local lowerTorso = character:FindFirstChild("LowerTorso") or upperTorso
        
        if head and upperTorso then
            local function drawBone(from, to, line)
                if not from or not to or not line then line.Visible = false return end
                local fromScreen, fromVis = Camera:WorldToViewportPoint(from.Position)
                if not fromVis or fromScreen.Z <= 0 then line.Visible = false return end
                local toScreen, toVis = Camera:WorldToViewportPoint(to.Position)
                if not toVis or toScreen.Z <= 0 then line.Visible = false return end
                line.From = Vector2.new(fromScreen.X, fromScreen.Y)
                line.To = Vector2.new(toScreen.X, toScreen.Y)
                line.Color = ESPSettings.SkeletonColor
                line.Visible = true
            end
            
            if skeleton.Head then drawBone(head, upperTorso, skeleton.Head) end
            if skeleton.UpperSpine then drawBone(upperTorso, lowerTorso, skeleton.UpperSpine) end
            
            local leftArm = character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("Left Arm")
            local rightArm = character:FindFirstChild("RightUpperArm") or character:FindFirstChild("Right Arm")
            local leftLeg = character:FindFirstChild("LeftUpperLeg") or character:FindFirstChild("Left Leg")
            local rightLeg = character:FindFirstChild("RightUpperLeg") or character:FindFirstChild("Right Leg")
            
            if leftArm and skeleton.LeftShoulder then drawBone(upperTorso, leftArm, skeleton.LeftShoulder) elseif skeleton.LeftShoulder then skeleton.LeftShoulder.Visible = false end
            if rightArm and skeleton.RightShoulder then drawBone(upperTorso, rightArm, skeleton.RightShoulder) elseif skeleton.RightShoulder then skeleton.RightShoulder.Visible = false end
            if leftLeg and skeleton.LeftHip then drawBone(lowerTorso, leftLeg, skeleton.LeftHip) elseif skeleton.LeftHip then skeleton.LeftHip.Visible = false end
            if rightLeg and skeleton.RightHip then drawBone(lowerTorso, rightLeg, skeleton.RightHip) elseif skeleton.RightHip then skeleton.RightHip.Visible = false end
        else
            for _, line in pairs(skeleton) do if line then line.Visible = false end end
        end
    elseif skeleton then
        for _, line in pairs(skeleton) do if line then line.Visible = false end end
    end
end

local function CleanupESP()
    for _, player in ipairs(Players:GetPlayers()) do
        RemoveESP(player)
    end
    
    for player, _ in pairs(Drawings.ESP) do
        RemoveESP(player)
    end
    
    for player, highlight in pairs(Highlights) do
        pcall(function() highlight:Destroy() end)
    end
    
    for player, skeleton in pairs(Drawings.Skeleton) do
        for _, line in pairs(skeleton) do
            pcall(function() line:Remove() end)
        end
    end
    
    Drawings.ESP = {}
    Drawings.Skeleton = {}
    Highlights = {}
    lastESPUpdate = {}
end

-- Cleanup function
local function DestroyAllFunctions()
    print("[YBA Enhanced] Начало уничтожения скрипта...")
    ScriptDestroyed = true
    
    -- Stop all functions with pcall
    pcall(function() if isFlying then StopFly() end end)
    pcall(function() if isNoClipping then StopNoClip() end end)
    pcall(function() if isSpeedHacking then StopSpeed() end end)
    pcall(function() if isInfiniteJumping then StopInfiniteJump() end end)
    pcall(function() if isJumpHacking then StopJumpHack() end end)
    pcall(function() if isStandControlActive then StopStandControl() end end)
    pcall(function() if isAutofarmEnabled then StopAutofarm() end end)
    pcall(function() if isAutosellEnabled then StopAutosell() end end)
    pcall(function() if isAutobuyEnabled then StopAutobuy() end end)
    pcall(function() if isMoneyFarmEnabled then StopMoneyFarm() end end)
    pcall(function() if consoleEnabled then StopConsole() end end)
    pcall(function() if commandHandlerEnabled then StopCommandHandler() end end)
    
    print("[YBA Enhanced] Все функции остановлены")
    
    -- КРИТИЧНО: Удаляем консоль
    pcall(function()
        if Console and Console.Destroy then
            Console.Destroy()
            print("[YBA Enhanced] Консоль удалена")
        end
    end)
    
    -- КРИТИЧНО: Удаляем старую консоль из CoreGui если она осталась
    pcall(function()
        local CoreGui = game:GetService("CoreGui")
        local oldConsole = CoreGui:FindFirstChild("DexConsole")
        if oldConsole then
            oldConsole:Destroy()
            print("[YBA Enhanced] Старая консоль удалена из CoreGui")
        end
    end)
    
    -- Cleanup ESP completely
    pcall(function()
        ESPSettings.Enabled = false
        CleanupESP()
    end)
    
    print("[YBA Enhanced] ESP очищен")
    
    -- Disconnect all global connections
    for _, connection in pairs(globalConnections) do
        pcall(function()
            if typeof(connection) == "RBXScriptConnection" then
                connection:Disconnect()
            elseif typeof(connection) == "thread" then
                task.cancel(connection)
            end
        end)
    end
    globalConnections = {}
    
    print("[YBA Enhanced] Все соединения отключены")
    
    -- Destroy platform
    pcall(function()
        DestroyFarmPlatform()
    end)
    
    print("[YBA Enhanced] Платформа удалена")
    
    -- Destroy UI
    pcall(function()
        if Library and Library.Unloaded == false then
            Library:Destroy()
        end
    end)
    
    print("[YBA Enhanced] UI уничтожен")
    
    -- Clear all settings to prevent restart
    Settings.Fly = false
    Settings.NoClip = false
    Settings.Speed = false
    Settings.InfiniteJump = false
    Settings.JumpHack = false
    Settings.StandControl = false
    Settings.Autofarm = false
    Settings.Autosell = false
    Settings.Platform = false
    
    -- Clear global flag
    _G.YBAEnhancedLoaded = false
    _G.YBAEnhancedCleanup = nil
    
    print("[YBA Enhanced] Скрипт полностью уничтожен!")
end

