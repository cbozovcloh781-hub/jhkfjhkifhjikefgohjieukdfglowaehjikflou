-- Teleport Functions
local lastTeleportPos = nil
local stuckCheckTimer = 0
local stuckCounter = 0

-- КРИТИЧНО: Функция для полного сброса переменных телепорта
local function ResetTeleportVariables()
    lastTeleportPos = nil
    stuckCheckTimer = 0
    stuckCounter = 0
end

local function isPlayerStuck()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local currentPos = character.HumanoidRootPart.Position
    
    if lastTeleportPos then
        local distance = (currentPos - lastTeleportPos).Magnitude
        if distance < 2 and tick() - stuckCheckTimer > 3 then
            stuckCounter = stuckCounter + 1
            if stuckCounter > 3 then
                return true
            end
        else
            stuckCounter = 0
        end
    end
    
    lastTeleportPos = currentPos
    stuckCheckTimer = tick()
    return false
end

local function instantTeleport(targetPos)
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    rootPart.CFrame = CFrame.new(targetPos)
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    return true
end

local function bypassTeleport(targetPos)
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    local startPos = rootPart.Position
    local distance = (targetPos - startPos).Magnitude
    
    -- КРИТИЧНО: Принудительная инициализация переменных
    if not lastTeleportPos then
        lastTeleportPos = startPos
        stuckCheckTimer = tick()
        stuckCounter = 0
    end
    
    if distance < 40 then
        instantTeleport(targetPos)
        return true
    end
    
    local stepSize, stepDelay
    
    if distance < 100 then
        stepSize = 31
        stepDelay = 0.024
    elseif distance < 300 then
        stepSize = 36
        stepDelay = 0.022
    elseif distance < 600 then
        stepSize = 43
        stepDelay = 0.020
    else
        stepSize = 46
        stepDelay = 0.019
    end
    
    local direction = (targetPos - startPos).Unit
    local steps = math.ceil(distance / stepSize)
    
    for i = 1, steps do
        if not isAutofarmEnabled then break end
        
        local stepPos
        if i == steps then
            stepPos = targetPos
        else
            stepPos = rootPart.Position + (direction * stepSize)
        end
        
        rootPart.CFrame = CFrame.new(stepPos)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        task.wait(stepDelay)
    end
    
    instantTeleport(targetPos)
    task.wait(0.025)
    
    return true
end

