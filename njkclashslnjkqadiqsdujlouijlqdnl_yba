local function AddConsoleLog(text, color)
    if not consoleOutput then return end
    
    local logLabel = Instance.new("TextLabel")
    logLabel.Size = UDim2.new(1, -10, 0, 20)
    logLabel.BackgroundTransparency = 1
    logLabel.Text = "[" .. os.date("%H:%M:%S") .. "] " .. text
    logLabel.TextColor3 = color or Color3.new(1, 1, 1)
    logLabel.TextSize = 12
    logLabel.Font = Enum.Font.Gotham
    logLabel.TextXAlignment = Enum.TextXAlignment.Left
    logLabel.TextWrapped = true
    logLabel.Parent = consoleOutput
    
    local layout = consoleOutput:FindFirstChild("UIListLayout")
    if layout then
        consoleOutput.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y)
        consoleOutput.CanvasPosition = Vector2.new(0, consoleOutput.CanvasSize.Y.Offset)
    end
end

local function ExecuteCommand(command)
    AddConsoleLog("> " .. command, Color3.new(0, 1, 0))
    
    local args = command:split(" ")
    local cmd = args[1]:lower()
    
    if cmd == "help" then
        AddConsoleLog("Available commands:", Color3.new(1, 1, 0))
        AddConsoleLog("help - Show this help", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("clear - Clear console", Color3.new(0.8, 0.8, 0.8))

        AddConsoleLog("tp [x] [y] [z] - Teleport to coordinates", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("speed [value] - Set walk speed", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("fly [on/off] - Toggle fly", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("noclip [on/off] - Toggle noclip", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("testdialogue [option] [dialogue] - Test Merchant dialogue", Color3.new(0.8, 0.8, 0.8))
        AddConsoleLog("lua [code] - Execute Lua code", Color3.new(0.8, 0.8, 0.8))
    elseif cmd == "clear" then
        for _, child in pairs(consoleOutput:GetChildren()) do
            if child:IsA("TextLabel") then
                child:Destroy()
            end
        end

    elseif cmd == "tp" and #args >= 4 then
        local x, y, z = tonumber(args[2]), tonumber(args[3]), tonumber(args[4])
        if x and y and z then
            local character = Player.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                character.HumanoidRootPart.CFrame = CFrame.new(x, y, z)
                AddConsoleLog("Teleported to " .. x .. ", " .. y .. ", " .. z, Color3.new(0, 1, 1))
            end
        else
            AddConsoleLog("Invalid coordinates", Color3.new(1, 0, 0))
        end
    elseif cmd == "speed" and #args >= 2 then
        local speed = tonumber(args[2])
        if speed then
            local character = Player.Character
            if character and character:FindFirstChild("Humanoid") then
                character.Humanoid.WalkSpeed = speed
                AddConsoleLog("Speed set to " .. speed, Color3.new(0, 1, 1))
            end
        else
            AddConsoleLog("Invalid speed value", Color3.new(1, 0, 0))
        end
    elseif cmd == "fly" and #args >= 2 then
        local state = args[2]:lower()
        if state == "on" then
            StartFly()
            AddConsoleLog("Fly enabled", Color3.new(0, 1, 1))
        elseif state == "off" then
            StopFly()
            AddConsoleLog("Fly disabled", Color3.new(0, 1, 1))
        end
    elseif cmd == "noclip" and #args >= 2 then
        local state = args[2]:lower()
        if state == "on" then
            StartNoClip()
            AddConsoleLog("NoClip enabled", Color3.new(0, 1, 1))
        elseif state == "off" then
            StopNoClip()
            AddConsoleLog("NoClip disabled", Color3.new(0, 1, 1))
        end
    elseif cmd == "testdialogue" and #args >= 3 then
        local option = args[2]
        local dialogue = args[3]
        local character = Player.Character
        if character and character:FindFirstChild("RemoteEvent") then
            local args = {
                [1] = "EndDialogue",
                [2] = {
                    ["NPC"] = "Merchant",
                    ["Option"] = option,
                    ["Dialogue"] = dialogue
                }
            }
            character.RemoteEvent:FireServer(unpack(args))
            AddConsoleLog("Sent: Option=" .. option .. ", Dialogue=" .. dialogue, Color3.new(0, 1, 1))
        else
            AddConsoleLog("Character or RemoteEvent not found", Color3.new(1, 0, 0))
        end
    elseif cmd == "lua" and #args >= 2 then
        local code = command:sub(5)
        local success, result = pcall(function()
            return loadstring(code)()
        end)
        if success then
            AddConsoleLog("Executed: " .. tostring(result), Color3.new(0, 1, 1))
        else
            AddConsoleLog("Error: " .. tostring(result), Color3.new(1, 0, 0))
        end
    else
        AddConsoleLog("Unknown command. Type 'help' for available commands.", Color3.new(1, 0, 0))
    end
end

local function StartConsole()
    if consoleEnabled then return end
    consoleEnabled = true
    
    pcall(function()
        CreateConsole()
    end)
    
    -- Hook into game logs
    pcall(function()
        consoleConnections.logService = game:GetService("LogService").MessageOut:Connect(function(message, messageType)
            if not consoleEnabled then return end
            
            local color = Color3.new(1, 1, 1)
            if messageType == Enum.MessageType.MessageError then
                color = Color3.new(1, 0, 0)
            elseif messageType == Enum.MessageType.MessageWarning then
                color = Color3.new(1, 1, 0)
            elseif messageType == Enum.MessageType.MessageInfo then
                color = Color3.new(0, 1, 1)
            end
            
            AddConsoleLog(message, color)
        end)
    end)
    
    -- Hook into script errors
    pcall(function()
        consoleConnections.scriptContext = game:GetService("ScriptContext").Error:Connect(function(message, stack, script)
            if not consoleEnabled then return end
            AddConsoleLog("SCRIPT ERROR: " .. message, Color3.new(1, 0, 0))
            if stack and stack ~= "" then
                AddConsoleLog("Stack: " .. stack, Color3.new(0.8, 0.4, 0.4))
            end
        end)
    end)
    
    pcall(function()
        AddConsoleLog("Custom console initialized", Color3.new(0, 1, 0))
    end)
end

local function StopConsole()
    if not consoleEnabled then return end
    consoleEnabled = false
    
    pcall(function()
        DestroyConsole()
    end)
end

