                    ChamsFillColor = {R = ESPSettings.ChamsFillColor.R, G = ESPSettings.ChamsFillColor.G, B = ESPSettings.ChamsFillColor.B}
                }
            }
            
            local HttpService = game:GetService("HttpService")
            local encoded = HttpService:JSONEncode(config)
            writefile("YBAEnhanced/autosave.json", encoded)
        end)
    end)
end

local function LoadConfigFromFile()
    local success = pcall(function()
        if not isfile("YBAEnhanced/autosave.json") then
            return false
        end
        
        local HttpService = game:GetService("HttpService")
        local file = readfile("YBAEnhanced/autosave.json")
        local config = HttpService:JSONDecode(file)
        
        -- Load Settings
        for key, value in pairs(config.Settings) do
            Settings[key] = value
        end
        
        -- Load ESPSettings
        if config.ESPSettings then
            for key, value in pairs(config.ESPSettings) do
                ESPSettings[key] = value
            end
        end
        
        -- Load Colors
        if config.Colors then
            if config.Colors.Box then
                Colors.Box = Color3.new(config.Colors.Box.R, config.Colors.Box.G, config.Colors.Box.B)
            end
            if config.Colors.Tracer then
                Colors.Tracer = Color3.new(config.Colors.Tracer.R, config.Colors.Tracer.G, config.Colors.Tracer.B)
            end
            if config.Colors.Name then
                Colors.Name = Color3.new(config.Colors.Name.R, config.Colors.Name.G, config.Colors.Name.B)
            end
            if config.Colors.SkeletonColor then
                ESPSettings.SkeletonColor = Color3.new(config.Colors.SkeletonColor.R, config.Colors.SkeletonColor.G, config.Colors.SkeletonColor.B)
            end
            if config.Colors.ChamsFillColor then
                ESPSettings.ChamsFillColor = Color3.new(config.Colors.ChamsFillColor.R, config.Colors.ChamsFillColor.G, config.Colors.ChamsFillColor.B)
            end
        end
        
        return true
    end)
    
    return success
end

