local function SellItem(itemName)
    local character = Player.Character
    if not character then return false end
    
    -- NOT SELLING Lucky Arrow and Lucky Stone Mask
    if itemName == "Lucky Arrow" or itemName == "Lucky Stone Mask" then
        return false
    end
    
    local item = Player.Backpack:FindFirstChild(itemName)
    if not item then return false end
    
    -- Equip item
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:EquipTool(item)
        task.wait(0.05)
    end
    
    -- Call RemoteEvent for selling
    local remoteEvent = character:FindFirstChild("RemoteEvent")
    if remoteEvent then
        local args = {
            [1] = "EndDialogue",
            [2] = {
                ["NPC"] = "Merchant",
                ["Option"] = "Option2",
                ["Dialogue"] = "Dialogue5"
            }
        }
        remoteEvent:FireServer(unpack(args))
        return true
    end
    
    return false
end

local function StartAutosell()
    if isAutosellEnabled then return end
    isAutosellEnabled = true
    
    -- КРИТИЧНО: Обновляем _G переменные при запуске автопродажи
    _G.YBAAutoSellEnabled = true
    _G.YBASellItems = Settings.SellItems
    
    -- Reset sold items counter
    farmStats.itemsSold = 0
    
    Library:Notify({
        Title = "Autosell",
        Content = "Автопродажа запущена! Лимит: $1,000,000",
        Duration = 3
    })
    
    task.spawn(function()
        while isAutosellEnabled do
            local selectedItems = Options.SellItems and Options.SellItems.Value or Settings.SellItems
            
            if type(selectedItems) == "table" then
                local itemsSold = 0
                local itemsToSell = {}
                
                -- Collect all items for sale
                for _, item in pairs(Player.Backpack:GetChildren()) do
                    if item:IsA("Tool") then
                        local shouldSell = false
                        
                        for selectedItem, isSelected in pairs(selectedItems) do
                            if isSelected and (selectedItem == "All" or item.Name == selectedItem) then
                                shouldSell = true
                                break
                            end
                        end
                        
                        if shouldSell then
                            table.insert(itemsToSell, item.Name)
                        end
                    end
                end
                
                -- Sell items one by one with balance check
                for _, itemName in ipairs(itemsToSell) do
                    if not isAutosellEnabled then break end
                    
                    -- КРИТИЧНО: Проверяем баланс ПЕРЕД каждой продажей
                    local currentMoney = GetPlayerMoney()
                    
                    if currentMoney >= 1000000 then
                        Library:Notify({
                            Title = "Autosell",
                            Content = "Баланс достиг лимита $1,000,000! Автопродажа остановлена.",
                            Duration = 5
                        })
                        
                        -- Stop autosell
                        isAutosellEnabled = false
                        Settings.Autosell = false
                        _G.YBAAutoSellEnabled = false
                        
                        -- Wait until balance drops below 1M
                        task.spawn(function()
                            while true do
                                task.wait(5)
                                local money = GetPlayerMoney()
                                if money < 1000000 then
                                    Library:Notify({
                                        Title = "Autosell",
                                        Content = "Баланс упал ниже $1,000,000. Можно включить автопродажу снова.",
                                        Duration = 5
                                    })
                                    break
                                end
                            end
                        end)
                        
                        break
                    end
                    
                    -- Проверяем не превысим ли лимит после продажи
                    local itemPrice = itemPrices[itemName] or 0
                    
                    -- НОВАЯ ЛОГИКА: Если близко к лимиту, продаем самый дешевый предмет
                    if currentMoney + itemPrice > 1000000 then
                        -- Ищем самый дешевый предмет в инвентаре
                        local cheapestItem = nil
                        local cheapestPrice = math.huge
                        
                        for _, checkItemName in ipairs(itemsToSell) do
                            local checkPrice = itemPrices[checkItemName] or 0
                            if checkPrice > 0 and checkPrice < cheapestPrice then
                                cheapestItem = checkItemName
                                cheapestPrice = checkPrice
                            end
                        end
                        
                        -- Если текущий предмет самый дешевый - продаем его
                        if itemName == cheapestItem then
                            print("[Autosell] Продажа " .. itemName .. " ($" .. itemPrice .. ") несмотря на превышение лимита (самый дешевый)")
                            Library:Notify({
                                Title = "Autosell",
                                Content = "Продажа " .. itemName .. " (самый дешевый) для освобождения места",
                                Duration = 3
                            })
                        else
                            -- Пропускаем более дорогие предметы
                            print("[Autosell] Пропуск " .. itemName .. " ($" .. itemPrice .. ") - превысит лимит")
                            continue
                        end
                    end
                    
                    if SellItem(itemName) then
                        itemsSold = itemsSold + 1
                        farmStats.itemsSold = (farmStats.itemsSold or 0) + 1
                        farmStats.moneySold = (farmStats.moneySold or 0) + itemPrice
                        
                        -- КРИТИЧНО: Сохраняем в _G для сохранения между сессиями
                        _G.YBAItemsSold = farmStats.itemsSold
                        _G.YBAMoneySold = farmStats.moneySold
                        
                        print("[Autosell] Продан " .. itemName .. " за $" .. itemPrice .. " (баланс: $" .. (currentMoney + itemPrice) .. ")")
                        print("[Autosell] Статистика: Собрано $" .. farmStats.moneyCollected .. " | Продано $" .. farmStats.moneySold)
                    end
                    task.wait(0.05)
                end
                
                if itemsSold > 0 then
                    local newBalance = GetPlayerMoney()
                    Library:Notify({
                        Title = "Продано",
                        Content = itemsSold .. " предметов (баланс: $" .. newBalance .. ")",
                        Duration = 2
                    })
                end
            end
            
            task.wait(0.5)
        end
    end)
end

