 playerlist.Size = UDim2.new(playerlist.Size.X.Scale, playerlist.Size.X.Offset, playerlist.Size.Y.Scale, playerlist.Size.Y.Offset) end end end) detectedCheaters = {} cheaterTimers = {} playerPositions = {} if cheaterViewThread then pcall(function() task.cancel(cheaterViewThread) end) cheaterViewThread = nil end if cheaterDetectionThread then pcall(function() task.cancel(cheaterDetectionThread) end) cheaterDetectionThread = nil end end end})

-- КРИТИЧНО: Автозапуск CheaterView при загрузке скрипта
if Settings.CheaterViewEnabled and cheaterViewEnabled then
    task.spawn(function()
        task.wait(1)
        pcall(function() local playerGui = game:GetService("Players").LocalPlayer.PlayerGui local hud = playerGui:FindFirstChild("HUD") if hud then local playerlist = hud:FindFirstChild("Playerlist") if playerlist then playerlist.Size = UDim2.new(playerlist.Size.X.Scale, playerlist.Size.X.Offset, 0.7, 0) end end end)
        UpdatePlayerlistCheaterTags()
        if cheaterDetectionThread then pcall(function() task.cancel(cheaterDetectionThread) end) end
        cheaterDetectionThread = task.spawn(function()
            while cheaterViewEnabled do
                local currentTime = tick()
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local currentPos = player.Character.HumanoidRootPart.Position
                        if playerPositions[player.UserId] then
                            local lastPos = playerPositions[player.UserId].Position
                            local lastTime = playerPositions[player.UserId].Time
                            local timeDiff = currentTime - lastTime
                            if timeDiff > 0.5 and timeDiff < 2 then
                                local distance = (currentPos - lastPos).Magnitude
                                local speed = distance / timeDiff
                                if speed > 600 then
                                    if not detectedCheaters[player.UserId] then
                                        detectedCheaters[player.UserId] = true
                                    end
                                    cheaterTimers[player.UserId] = currentTime
                                end
                            end
                        end
                        playerPositions[player.UserId] = {Position = currentPos, Time = tick()}
                    end
                end
                for userId, lastViolation in pairs(cheaterTimers) do
                    if currentTime - lastViolation >= 60 then
                        detectedCheaters[userId] = nil
                        cheaterTimers[userId] = nil
                    end
                end
                task.wait(0.5)
            end
            cheaterDetectionThread = nil
        end)
    end)
end

