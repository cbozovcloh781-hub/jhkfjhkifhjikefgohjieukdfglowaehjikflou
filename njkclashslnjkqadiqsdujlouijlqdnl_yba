local function loadSettings()
    local success, saved = pcall(function()
        return game:GetService("HttpService"):JSONDecode(readfile("YBA_Enhanced_Settings.json"))
    end)
    if success and saved then
        for key, value in pairs(DefaultSettings) do
            Settings[key] = saved[key] ~= nil and saved[key] or value
        end
        -- КРИТИЧНО: Загружаем состояние автофарма и автоселла
        if saved.Autofarm ~= nil then
            Settings.Autofarm = saved.Autofarm
            print("[YBA Enhanced] Загружено Autofarm: " .. tostring(Settings.Autofarm))
        end
        if saved.Autosell ~= nil then
            Settings.Autosell = saved.Autosell
            print("[YBA Enhanced] Загружено Autosell: " .. tostring(Settings.Autosell))
        end
        if saved.FarmItems and type(saved.FarmItems) == "table" then
            Settings.FarmItems = saved.FarmItems
            print("[YBA Enhanced] Загружено FarmItems: " .. game:GetService("HttpService"):JSONEncode(Settings.FarmItems))
        else
            Settings.FarmItems = {}
        end
        if saved.SellItems and type(saved.SellItems) == "table" then
            Settings.SellItems = saved.SellItems
            print("[YBA Enhanced] Загружено SellItems: " .. game:GetService("HttpService"):JSONEncode(Settings.SellItems))
        else
            Settings.SellItems = {}
        end
        if saved.ESPSettings then for k, v in pairs(saved.ESPSettings) do ESPSettings[k] = v end end
        if saved.ESPColors then
            if saved.ESPColors.Box then Colors.Box = Color3.fromRGB(saved.ESPColors.Box.R, saved.ESPColors.Box.G, saved.ESPColors.Box.B) end
            if saved.ESPColors.Tracer then Colors.Tracer = Color3.fromRGB(saved.ESPColors.Tracer.R, saved.ESPColors.Tracer.G, saved.ESPColors.Tracer.B) end
            if saved.ESPColors.Name then Colors.Name = Color3.fromRGB(saved.ESPColors.Name.R, saved.ESPColors.Name.G, saved.ESPColors.Name.B) end
        end
    else
        Settings = table.clone(DefaultSettings)
    end
end

