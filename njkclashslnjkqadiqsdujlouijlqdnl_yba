-- Update player list periodically
globalConnections.playerListUpdate = spawn(function()
    while not ScriptDestroyed do
        wait(5)
        if PlayerDropdown then
            PlayerDropdown:SetValues(GetAlivePlayers())
        end
    end
end)

-- Character respawn handling
globalConnections.characterAdded = Player.CharacterAdded:Connect(function(newCharacter)
    if ScriptDestroyed then return end
    wait(1)
    
    if Settings.Speed then
        StartSpeed()
    end
    if Settings.InfiniteJump then
        StartInfiniteJump()
    end
    if Settings.JumpHack then
        StartJumpHack()
    end
    
    local humanoid = newCharacter:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        task.wait(5)
        if Settings.Autofarm then
            StartAutofarm()
        end
    end)
    
    if Settings.Autofarm then
        task.wait(0.5)
        StartAutofarm()
    end
end)

-- ESP Update Loop (60 FPS)
task.spawn(function() while task.wait(0.016) do Colors.Rainbow = Color3.fromHSV(tick() * ESPSettings.RainbowSpeed % 1, 1, 1) end end)
if DrawingSupported then
    globalConnections.espUpdate = RunService.RenderStepped:Connect(function()
        if not ESPSettings.Enabled then DisableESP() return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not Drawings.ESP[player] then CreateESP(player) end
                UpdateESP(player)
            end
        end
    end)
end

Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer and DrawingSupported then CreateESP(player) end
end)

Players.PlayerRemoving:Connect(RemoveESP)

if DrawingSupported then
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then CreateESP(player) end
    end
end

-- АВТОЗАГРУЗКА: Используй yba_autoloader.lua в workspace папке Solara
-- queue_on_teleport НЕ РАБОТАЕТ в Solara, поэтому используем autoloader
print("[YBA Enhanced] Для автозагрузки после server hop используй yba_autoloader.lua в workspace")

-- Но сохраняем настройки перед телепортом в _G переменные
game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(State)
    if State == Enum.TeleportState.Started then
        print("[YBA Enhanced] Телепортация началась - сохранение настроек...")
        
        _G.YBAAutoRestart = true
        _G.YBAAutoFarmEnabled = Settings.Autofarm
        _G.YBAAutoSellEnabled = Settings.Autosell
        _G.YBAFarmItems = Settings.FarmItems
        _G.YBASellItems = Settings.SellItems
        _G.YBAAutoServerHop = Settings.AutoServerHop
        
        print("[YBA Enhanced] Настройки сохранены в _G переменные")
        print("[YBA Enhanced] Autofarm: " .. tostring(_G.YBAAutoFarmEnabled))
        print("[YBA Enhanced] Autosell: " .. tostring(_G.YBAAutoSellEnabled))
    end
end)

-- УДАЛЕНО: Автозапуск теперь происходит ПОСЛЕ нажатия кнопки Play (см. выше)

-- Apply startup settings after a small delay to ensure everything is loaded
globalConnections.startupSettings = spawn(function()
    wait(2)  -- Увеличена задержка для полной загрузки UI
    if ScriptDestroyed then return end
    
    print("[YBA Enhanced] === Автозапуск настроек (НЕ АВТОФАРМ) ===")
    
    if Settings.Fly then StartFly() print("[YBA Enhanced] Fly запущен") end
    if Settings.NoClip then StartNoClip() print("[YBA Enhanced] NoClip запущен") end
    if Settings.Speed then StartSpeed() print("[YBA Enhanced] Speed запущен") end
    if Settings.InfiniteJump then StartInfiniteJump() print("[YBA Enhanced] InfiniteJump запущен") end
    if Settings.JumpHack then StartJumpHack() print("[YBA Enhanced] JumpHack запущен") end
    if Settings.StandControl then StartStandControl() print("[YBA Enhanced] StandControl запущен") end
    if Settings.Platform then CreateFarmPlatform() print("[YBA Enhanced] Platform создана") end
    
    -- КРИТИЧНО: Восстанавливаем ESP если он был включен
    if ESPSettings.Enabled and DrawingSupported then
        print("[YBA Enhanced] Восстановление ESP...")
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                CreateESP(player)
            end
        end
        Library:Notify({
            Title = "ESP",
            Content = "ESP восстановлен после перезагрузки!",
            Duration = 3
        })
    end
    
    -- ВАЖНО: Автофарм и автопродажа запускаются ПОСЛЕ нажатия кнопки Play!
    print("[YBA Enhanced] === Автозапуск завершен (автофарм запустится после Play) ===")
end)

