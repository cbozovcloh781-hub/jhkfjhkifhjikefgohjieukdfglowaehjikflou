AutoTab:AddButton({
    Title = "📊 Показать статистику фарма",
    Description = "Детальная статистика собранных/проданных предметов",
    Callback = function()
        local uptime = math.floor(tick() - farmStats.startTime)
        local days = math.floor(uptime / 86400)
        local hours = math.floor((uptime % 86400) / 3600)
        local minutes = math.floor((uptime % 3600) / 60)
        local seconds = uptime % 60
        
        local uptimeStr
        if days > 0 then
            uptimeStr = string.format("%dд %02dч %02dм %02dс", days, hours, minutes, seconds)
        elseif hours > 0 then
            uptimeStr = string.format("%dч %02dм %02dс", hours, minutes, seconds)
        else
            uptimeStr = string.format("%dм %02dс", minutes, seconds)
        end
        
        local totalItems = 0
        local sellableItems = 0
        local sellableValue = 0
        local luckyArrows = 0
        local luckyMasks = 0
        
        for _, item in pairs(Player.Backpack:GetChildren()) do
            if item:IsA("Tool") then
                totalItems = totalItems + 1
                
                if item.Name == "Lucky Arrow" then
                    luckyArrows = luckyArrows + 1
                elseif item.Name == "Lucky Stone Mask" then
                    luckyMasks = luckyMasks + 1
                end
                
                local itemPrice = itemPrices[item.Name] or 0
                if itemPrice > 0 and item.Name ~= "Lucky Arrow" and item.Name ~= "Lucky Stone Mask" then
                    sellableItems = sellableItems + 1
                    sellableValue = sellableValue + itemPrice
                end
            end
        end
        
        Library:Notify({
            Title = "📊 Статистика фарма",
            Content = "Собрано: " .. farmStats.itemsCollected .. " ($" .. farmStats.moneyCollected .. ")\nПродано: " .. farmStats.itemsSold .. " ($" .. farmStats.moneySold .. ")\nВремя: " .. uptimeStr .. "\n\nИнвентарь: " .. totalItems .. " предметов\nМожно продать: " .. sellableItems .. " ($" .. sellableValue .. ")\nLucky Arrow: " .. luckyArrows .. "\nLucky Mask: " .. luckyMasks,
            Duration = 8
        })
    end
})

