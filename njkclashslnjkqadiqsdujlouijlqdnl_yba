        -- Метод 1: VirtualInputManager Tab+Enter навигация
        pcall(function()
            local vim = game:GetService("VirtualInputManager")
            -- Нажимаем Tab несколько раз чтобы выбрать кнопку
            for i = 1, 5 do
                vim:SendKeyEvent(true, Enum.KeyCode.Tab, false, game)
                task.wait(0.03)
                vim:SendKeyEvent(false, Enum.KeyCode.Tab, false, game)
                task.wait(0.03)
            end
            -- Нажимаем Enter
            vim:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            task.wait(0.05)
            vim:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        end)
        
        -- Метод 2: GuiService.SelectedObject + Enter
        pcall(function()
            game:GetService("GuiService").SelectedObject = playButton
            task.wait(0.05)
            local vim = game:GetService("VirtualInputManager")
            vim:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            task.wait(0.05)
            vim:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        end)
        
        -- Метод 3: VirtualInputManager Space (альтернатива Enter)
        pcall(function()
            game:GetService("GuiService").SelectedObject = playButton
            task.wait(0.05)
            local vim = game:GetService("VirtualInputManager")
            vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.05)
            vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end)
        
        -- Метод 4: Прямой вызов функции кнопки (если есть)
        if attempt % 10 == 0 then
            pcall(function()
                if playButton:IsA("GuiButton") or playButton:IsA("TextButton") or playButton:IsA("ImageButton") then
                    -- Пытаемся найти и вызвать функцию обработчика
                    for _, connection in pairs(getconnections(playButton.MouseButton1Click)) do
                        pcall(function()
                            connection:Fire()
                        end)
                    end
                    for _, connection in pairs(getconnections(playButton.Activated)) do
                        pcall(function()
                            connection:Fire()
                        end)
                    end
                end
            end)
        end
        
        -- Метод 5: Изменение свойств LoadingScreen напрямую
        if attempt % 20 == 0 then
            pcall(function()
                loadingScreen.Enabled = false
                print("[YBA Enhanced] Попытка " .. attempt .. ": Отключен LoadingScreen.Enabled")
            end)
        end
        
        -- Метод 6: Удаление всех Frame внутри LoadingScreen
        if attempt > 50 then
