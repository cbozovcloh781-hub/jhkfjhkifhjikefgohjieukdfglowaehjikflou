            highlight.OutlineColor = Color3.fromRGB(255, 100, 0)
        else
            highlight.FillColor = ESPSettings.ChamsFillColor
            highlight.OutlineColor = ESPSettings.ChamsOutlineColor
        end
        highlight.FillTransparency = ESPSettings.ChamsTransparency 
        highlight.OutlineTransparency = ESPSettings.ChamsOutlineTransparency 
        highlight.Enabled = true 
    elseif highlight then 
        highlight.Enabled = false 
    end
    local skeleton = Drawings.Skeleton[player]
    if ESPSettings.SkeletonESP and skeleton then
        local head = character:FindFirstChild("Head")
        local upperTorso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        local lowerTorso = character:FindFirstChild("LowerTorso") or upperTorso
        
        if head and upperTorso then
            local function drawBone(from, to, line)
                if not from or not to or not line then line.Visible = false return end
                local fromScreen, fromVis = Camera:WorldToViewportPoint(from.Position)
                if not fromVis or fromScreen.Z <= 0 then line.Visible = false return end
                local toScreen, toVis = Camera:WorldToViewportPoint(to.Position)
                if not toVis or toScreen.Z <= 0 then line.Visible = false return end
                line.From = Vector2.new(fromScreen.X, fromScreen.Y)
                line.To = Vector2.new(toScreen.X, toScreen.Y)
                line.Color = ESPSettings.SkeletonColor
                line.Visible = true
            end
            
            if skeleton.Head then drawBone(head, upperTorso, skeleton.Head) end
            if skeleton.UpperSpine then drawBone(upperTorso, lowerTorso, skeleton.UpperSpine) end
            
            local leftArm = character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("Left Arm")
            local rightArm = character:FindFirstChild("RightUpperArm") or character:FindFirstChild("Right Arm")
            local leftLeg = character:FindFirstChild("LeftUpperLeg") or character:FindFirstChild("Left Leg")
            local rightLeg = character:FindFirstChild("RightUpperLeg") or character:FindFirstChild("Right Leg")
            
            if leftArm and skeleton.LeftShoulder then drawBone(upperTorso, leftArm, skeleton.LeftShoulder) elseif skeleton.LeftShoulder then skeleton.LeftShoulder.Visible = false end
            if rightArm and skeleton.RightShoulder then drawBone(upperTorso, rightArm, skeleton.RightShoulder) elseif skeleton.RightShoulder then skeleton.RightShoulder.Visible = false end
            if leftLeg and skeleton.LeftHip then drawBone(lowerTorso, leftLeg, skeleton.LeftHip) elseif skeleton.LeftHip then skeleton.LeftHip.Visible = false end
            if rightLeg and skeleton.RightHip then drawBone(lowerTorso, rightLeg, skeleton.RightHip) elseif skeleton.RightHip then skeleton.RightHip.Visible = false end
        else
            for _, line in pairs(skeleton) do if line then line.Visible = false end end
        end
    elseif skeleton then
        for _, line in pairs(skeleton) do if line then line.Visible = false end end
    end
end

local function CleanupESP()
    for _, player in ipairs(Players:GetPlayers()) do
        RemoveESP(player)
    end
    
    for player, _ in pairs(Drawings.ESP) do
        RemoveESP(player)
    end
    
    for player, highlight in pairs(Highlights) do
        pcall(function() highlight:Destroy() end)
    end
    
    for player, skeleton in pairs(Drawings.Skeleton) do
        for _, line in pairs(skeleton) do
            pcall(function() line:Remove() end)
        end
    end
    
    Drawings.ESP = {}
    Drawings.Skeleton = {}
    Highlights = {}
    lastESPUpdate = {}
end

-- Cleanup function
local function DestroyAllFunctions()
    
    ScriptDestroyed = true
    
    -- Stop all functions with pcall
    pcall(function() if isFlying then StopFly() end end)
    pcall(function() if isNoClipping then StopNoClip() end end)
    pcall(function() if isSpeedHacking then StopSpeed() end end)
    pcall(function() if isInfiniteJumping then StopInfiniteJump() end end)
    pcall(function() if isJumpHacking then StopJumpHack() end end)
    pcall(function() if isStandControlActive then StopStandControl() end end)
    pcall(function() if isAutofarmEnabled then StopAutofarm() end end)
    pcall(function() if isAutosellEnabled then StopAutosell() end end)
    pcall(function() if isAutobuyEnabled then StopAutobuy() end end)
    pcall(function() if isMoneyFarmEnabled then StopMoneyFarm() end end)
    pcall(function() if consoleEnabled then StopConsole() end end)
    pcall(function() if commandHandlerEnabled then StopCommandHandler() end end)
    
    pcall(function() 
        cheaterViewEnabled = false
        if cheaterViewThread then task.cancel(cheaterViewThread) cheaterViewThread = nil end
        if cheaterDetectionThread then task.cancel(cheaterDetectionThread) cheaterDetectionThread = nil end
    end)
    
    
    
    -- КРИТИЧНО: Удаляем консоль
    pcall(function()
        if Console and Console.Destroy then
            Console.Destroy()
            
        end
    end)
    
    -- КРИТИЧНО: Удаляем старую консоль из CoreGui если она осталась
    pcall(function()
        local CoreGui = game:GetService("CoreGui")
        local oldConsole = CoreGui:FindFirstChild("DexConsole")
        if oldConsole then
            oldConsole:Destroy()
            
        end
    end)
    
    -- Cleanup ESP completely
    pcall(function()
        ESPSettings.Enabled = false
        CleanupESP()
    end)
    
    
    
    -- Disconnect all global connections
    for _, connection in pairs(globalConnections) do
        pcall(function()
            if typeof(connection) == "RBXScriptConnection" then
                connection:Disconnect()
            elseif typeof(connection) == "thread" then
                task.cancel(connection)
            end
        end)
    end
    globalConnections = {}
    
    
    
    -- Destroy platform
    pcall(function()
        DestroyFarmPlatform()
    end)
    
    
    
    -- Destroy UI
    pcall(function()
        if Library and Library.Unloaded == false then
            Library:Destroy()
        end
    end)
    
    
    
    -- Clear all settings to prevent restart
    Settings.Fly = false
    Settings.NoClip = false
    Settings.Speed = false
    Settings.InfiniteJump = false
    Settings.JumpHack = false
    Settings.StandControl = false
    Settings.Autofarm = false
    Settings.Autosell = false
    Settings.Platform = false
    
    -- Clear global flag
    _G.YBAEnhancedLoaded = false
    _G.YBAEnhancedCleanup = nil
    
    
end

