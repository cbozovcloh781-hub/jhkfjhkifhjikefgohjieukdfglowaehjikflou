-- YBA Specific Functions
local function FindNearestStand()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local playerPosition = character.HumanoidRootPart.Position
    local nearestStand = nil
    local shortestDistance = Settings.StandRange
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name:find("Stand") and obj:FindFirstChild("HumanoidRootPart") then
            local distance = (obj.HumanoidRootPart.Position - playerPosition).Magnitude
            if distance < shortestDistance then
                nearestStand = obj
                shortestDistance = distance
            end
        end
    end
    
    return nearestStand
end

local function StartStandControl()
    if isStandControlActive then return end
    isStandControlActive = true
    
    local stand = FindNearestStand()
    if not stand then
        Library:Notify({
            Title = "Stand Control",
            Content = "No stand found nearby",
            Duration = 3
        })
        return
    end
    
    local character = Player.Character
    if not character then return end
    
    if Settings.FreezePlayer then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 0
            humanoid.JumpPower = 0
        end
    end
    
    standConnections.heartbeat = RunService.Heartbeat:Connect(function()
        if not isStandControlActive then return end
        
        local mouse = Player:GetMouse()
        local camera = workspace.CurrentCamera
        
        if stand and stand:FindFirstChild("HumanoidRootPart") then
            local moveVector = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveVector = moveVector + camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveVector = moveVector - camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveVector = moveVector - camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveVector = moveVector + camera.CFrame.RightVector
            end
            
            if moveVector.Magnitude > 0 then
                stand.HumanoidRootPart.CFrame = stand.HumanoidRootPart.CFrame + moveVector.Unit * 2
            end
        end
    end)
end

local function StopStandControl()
    if not isStandControlActive then return end
    isStandControlActive = false
    
    for _, connection in pairs(standConnections) do
        connection:Disconnect()
    end
    standConnections = {}
    
    local character = Player.Character
    if character and Settings.FreezePlayer then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
        end
    end
end

-- БЕЗОПАСНАЯ СИСТЕМА (проверенные значения без киков)
local lastTeleportPos = nil
local stuckCheckTimer = 0
local stuckCounter = 0

local function isPlayerStuck()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local currentPos = character.HumanoidRootPart.Position
    
    if lastTeleportPos then
        local distance = (currentPos - lastTeleportPos).Magnitude
        if distance < 2 and tick() - stuckCheckTimer > 3 then
            stuckCounter = stuckCounter + 1
            if stuckCounter > 3 then
                return true
            end
        else
            stuckCounter = 0
        end
    end
    
    lastTeleportPos = currentPos
    stuckCheckTimer = tick()
    return false
end

-- Мгновенный телепорт
local function instantTeleport(targetPos)
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    rootPart.CFrame = CFrame.new(targetPos)
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    return true
end

-- ПРОВЕРЕННАЯ БЕЗОПАСНАЯ ТЕЛЕПОРТАЦИЯ (НЕ КИКАЕТ, НЕ ОТКАТЫВАЕТ)
local function bypassTeleport(targetPos)
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    local startPos = rootPart.Position
    local distance = (targetPos - startPos).Magnitude
    
    -- Если близко - мгновенный телепорт
    if distance < 40 then
        instantTeleport(targetPos)
        return true
    end
    
    -- ОЧЕНЬ БЫСТРАЯ СКОРОСТЬ (ускорено на 4%)
    local stepSize, stepDelay
    
    if distance < 100 then
        stepSize = 35.36
        stepDelay = 0.02688
    elseif distance < 300 then
        stepSize = 39.52
        stepDelay = 0.02496
    elseif distance < 600 then
        stepSize = 41.6
        stepDelay = 0.02304
    else
        stepSize = 43.68
        stepDelay = 0.02112
    end
    
    local direction = (targetPos - startPos).Unit
    local steps = math.ceil(distance / stepSize)
    
    for i = 1, steps do
        if not isAutofarmEnabled then break end
        
        local stepPos
        if i == steps then
            stepPos = targetPos
        else
            stepPos = rootPart.Position + (direction * stepSize)
        end
        
        -- Телепорт
        rootPart.CFrame = CFrame.new(stepPos)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        -- Задержка
        task.wait(stepDelay)
    end
    
    -- Финальный телепорт
    instantTeleport(targetPos)
    task.wait(0.03)
    
    return true
end

local function travelTo(place)
    local targetPos = place.Position
    bypassTeleport(targetPos)
end

local function TeleportToPlayer(targetPlayerName)
    local targetPlayer = FindPlayer(targetPlayerName)
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return false
    end
    
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local targetPos = targetPlayer.Character.HumanoidRootPart.Position + Vector3.new(math.random(-5, 5), 3, math.random(-5, 5))
    return bypassTeleport(targetPos)
end

