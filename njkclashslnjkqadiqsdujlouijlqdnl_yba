StartInfiniteJump = function()
    if isInfiniteJumping then return end
    isInfiniteJumping = true
    
    local character = Player.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(0, 9e9, 0)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    jumpConnections.bodyVelocity = bodyVelocity
    
    jumpConnections.heartbeat = RunService.Heartbeat:Connect(function()
        if not isInfiniteJumping then return end
        
        local currentCharacter = Player.Character
        if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then return end
        
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            if not bodyVelocity.Parent then
                bodyVelocity.Parent = currentCharacter.HumanoidRootPart
            end
            bodyVelocity.Velocity = Vector3.new(0, Settings.JumpHeight, 0)
        else
            if bodyVelocity.Parent then
                bodyVelocity.Parent = nil
            end
        end
    end)
    
    jumpConnections.characterAdded = Player.CharacterAdded:Connect(function(newCharacter)
        if not isInfiniteJumping then return end
        wait(0.1)
        
        local newRootPart = newCharacter:FindFirstChild("HumanoidRootPart")
        if newRootPart then
            if jumpConnections.bodyVelocity then
                jumpConnections.bodyVelocity:Destroy()
            end
            
            local newBodyVelocity = Instance.new("BodyVelocity")
            newBodyVelocity.MaxForce = Vector3.new(0, 9e9, 0)
            newBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            newBodyVelocity.Parent = newRootPart
            
            jumpConnections.bodyVelocity = newBodyVelocity
        end
    end)
end

StopInfiniteJump = function()
