function Console.AddLog(text, color)
    if not consoleOutput or not consoleOutput.Parent then return end
    
    local timestamp = "[" .. os.date("%H:%M:%S") .. "] "
    
    -- Экранируем специальные символы для RichText
    local function escapeRichText(str)
        return str:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
    end
    
    -- Определяем цвет по типу сообщения
    local colorHex = "#FFFFFF"
    
    -- Автоматическое определение цвета по ключевым словам
    if not color then
        if text:find("ERROR") or text:find("Error") or text:find("error") or text:find("ОШИБКА") or text:find("Ошибка") then
            colorHex = "#FF5050"
        elseif text:find("WARNING") or text:find("Warning") or text:find("ВНИМАНИЕ") or text:find("Предупреждение") then
            colorHex = "#FFC850"
        elseif text:find("SUCCESS") or text:find("Success") or text:find("УСПЕХ") or text:find("Успешно") then
            colorHex = "#50FF78"
        elseif text:find("INFO") or text:find("Info") or text:find("ИНФО") then
            colorHex = "#64C8FF"
        elseif text:find("DEBUG") or text:find("Debug") or text:find("ДЕБАГ") then
            colorHex = "#C896FF"
        elseif text:find("[YBA Enhanced]") or text:find("[Autofarm]") or text:find("[Autosell]") then
            colorHex = "#96FFC8"
        end
    else
        -- Конвертируем Color3 в hex
        colorHex = string.format("#%02X%02X%02X", 
            math.floor(color.R * 255), 
            math.floor(color.G * 255), 
            math.floor(color.B * 255)
        )
    end
    
    -- Экранируем текст
    local escapedText = escapeRichText(text)
    local escapedTimestamp = escapeRichText(timestamp)
    
    -- КРИТИЧНО: Проверяем длину текста ПЕРЕД добавлением
    local newPlainText = timestamp .. text .. "\n"
    local newColoredText = '<font color="#969696">' .. escapedTimestamp .. '</font><font color="' .. colorHex .. '">' .. escapedText .. '</font>\n'
    
    -- Если текст превысит лимит - очищаем старые логи (оставляем последние 50%)
    if #consoleOutput.Text + #newPlainText > 180000 then
        local lines = {}
        for line in consoleOutput.Text:gmatch("[^\n]+") do
            table.insert(lines, line)
        end
        
        -- Оставляем только последние 50% строк
        local halfPoint = math.floor(#lines / 2)
        local newText = ""
        for i = halfPoint, #lines do
            newText = newText .. lines[i] .. "\n"
        end
        
        consoleOutput.Text = newText
        
    end
    
    -- НОВОЕ: Добавляем ЧИСТЫЙ текст в TextBox (для копирования)
    consoleOutput.Text = consoleOutput.Text .. newPlainText
    
    -- НОВОЕ: Добавляем ЦВЕТНОЙ текст в TextLabel (для отображения)
    if consoleOutput.Parent and consoleOutput.Parent:IsA("ScrollingFrame") then
        local coloredDisplay = consoleOutput.Parent:FindFirstChild("ColoredDisplay")
        if coloredDisplay then
            -- Проверяем длину цветного текста
            if #coloredDisplay.Text + #newColoredText > 180000 then
                local lines = {}
                for line in coloredDisplay.Text:gmatch("[^\n]+") do
                    table.insert(lines, line)
                end
                
                local halfPoint = math.floor(#lines / 2)
                local newText = ""
                for i = halfPoint, #lines do
                    newText = newText .. lines[i] .. "\n"
                end
                
                coloredDisplay.Text = newText
            end
            
            coloredDisplay.Text = coloredDisplay.Text .. newColoredText
        end
    end
    
    -- КРИТИЧНО: Обновляем CanvasSize ТОЛЬКО если пользователь НЕ взаимодействует с консолью
    task.spawn(function()
        task.wait(0.1)  -- УВЕЛИЧЕНА задержка с 0.05 до 0.1
        if not consoleOutput then return end
        
        local scrollFrame = consoleOutput.Parent
        if scrollFrame and scrollFrame:IsA("ScrollingFrame") then
            -- НОВОЕ: Проверяем фокус на скролле (пользователь скроллит)
            local userInteracting = game:GetService("UserInputService"):IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
            
            if not userInteracting then
                -- ИСПРАВЛЕНО: Рассчитываем высоту текста вручную
                local textService = game:GetService("TextService")
                
                -- КРИТИЧНО: Используем ColoredDisplay для расчета высоты (т.к. он с RichText)
                local coloredDisplay = scrollFrame:FindFirstChild("ColoredDisplay")
                if coloredDisplay then
                    local textBounds = textService:GetTextSize(
                        coloredDisplay.Text,
                        coloredDisplay.TextSize,
                        coloredDisplay.Font,
                        Vector2.new(scrollFrame.AbsoluteSize.X - 20, math.huge)
                    )
                    
                    local textHeight = textBounds.Y + 20  -- +20 для отступа
                    
                    -- Устанавливаем CanvasSize равным высоте текста
                    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, textHeight)
                    
                    -- Автоскролл только если уже был внизу
                    if scrollFrame.AbsoluteCanvasSize and scrollFrame.AbsoluteWindowSize then
                        local maxScroll = scrollFrame.AbsoluteCanvasSize.Y - scrollFrame.AbsoluteWindowSize.Y
                        local currentScroll = scrollFrame.CanvasPosition.Y
                        -- Скроллим вниз только если уже были близко к низу (в пределах 100 пикселей)
                        if maxScroll - currentScroll < 100 then
                            scrollFrame.CanvasPosition = Vector2.new(0, scrollFrame.AbsoluteCanvasSize.Y)
                        end
                    end
                end
            end
        end
    end)
end

function Console.Clear()
    if not consoleOutput then return end
    consoleOutput.Text = ""
    
    -- Очищаем цветной дисплей
    local coloredDisplay = consoleOutput.Parent:FindFirstChild("ColoredDisplay")
    if coloredDisplay then
        coloredDisplay.Text = ""
    end
    
    -- Сбрасываем позицию скролла
