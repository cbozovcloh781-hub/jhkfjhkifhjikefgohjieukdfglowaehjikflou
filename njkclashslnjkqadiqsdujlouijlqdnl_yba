DebugTab:AddButton({
    Title = "Тест: Мониторинг игроков",
    Description = "Показывает скорость движения всех игроков",
    Callback = function()
        Library:Notify({
            Title = "Мониторинг",
            Content = "Сбор данных о скорости игроков...",
            Duration = 2
        })
        
        print("[DEBUG] === Мониторинг скорости игроков ===")
        
        task.spawn(function()
            local tempPositions = {}
            
            -- Записываем начальные позиции
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    tempPositions[player.UserId] = {
                        Position = player.Character.HumanoidRootPart.Position,
                        Time = tick(),
                        Name = player.Name
                    }
                end
            end
            
            task.wait(1)
            
            -- Измеряем скорость
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local currentPos = player.Character.HumanoidRootPart.Position
                    local data = tempPositions[player.UserId]
                    
                    if data then
                        local distance = (currentPos - data.Position).Magnitude
                        local timeDiff = tick() - data.Time
                        local speed = distance / timeDiff
                        
                        local status = speed > 400 and "[ЧИТЕР]" or "[OK]"
                        print("[DEBUG] " .. status .. " " .. player.Name .. ": " .. math.floor(speed) .. " стадов/сек")
                    end
                end
            end
            
            print("[DEBUG] === Мониторинг завершен ===")
            Library:Notify({
                Title = "Мониторинг",
                Content = "Данные выведены в консоль",
                Duration = 3
            })
        end)
    end
})

