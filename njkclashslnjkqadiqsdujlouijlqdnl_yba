                    return true
                end
            end
            return false
        end)
        
        if success and prestige > 0 then
            print("[YBA Enhanced] Престиж подтвержден: " .. prestige)
            break
        end
        
        task.wait(0.5)
    end
    
    if prestige == 0 and prestigeCheckAttempts >= maxPrestigeChecks then
        print("[YBA Enhanced] ВНИМАНИЕ: Престиж не определен за " .. maxPrestigeChecks .. " попыток! Используем престиж = 0")
