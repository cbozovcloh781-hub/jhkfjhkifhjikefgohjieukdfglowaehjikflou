-- Autofarm Functions
local function FindNearestItem()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    -- БЕЗОПАСНО: Проверяем что Options существует
    local selectedItems = Settings.FarmItems
    if Options and Options.FarmItems and Options.FarmItems.Value then
        selectedItems = Options.FarmItems.Value
    end
    local playerPosition = character.HumanoidRootPart.Position
    local nearestPrompt = nil
    local nearestItem = nil
    local shortestDistance = math.huge
    
    local itemSpawns = workspace:FindFirstChild("Item_Spawns")
    if not itemSpawns then return nil end
    
    local itemsFolder = itemSpawns:FindFirstChild("Items")
    if not itemsFolder then return nil end
    
    for _, itemModel in pairs(itemsFolder:GetChildren()) do
        if itemModel:IsA("Model") then
            local meshPart = itemModel:FindFirstChild("MeshPart")
            if meshPart and meshPart:FindFirstChild("PointLight") then
                local prompt = itemModel:FindFirstChildOfClass("ProximityPrompt")
                if prompt then
                    local itemName = prompt.ObjectText or "Unknown"
                    
                    local shouldFarm = false
                    if type(selectedItems) == "table" then
                        for selectedItem, isSelected in pairs(selectedItems) do
                            if isSelected and (selectedItem == "All" or itemName == selectedItem) then
                                shouldFarm = true
                                break
                            end
                        end
                    end
                    
                    if shouldFarm then
                        local distance = (meshPart.Position - playerPosition).Magnitude
                        if distance < shortestDistance then
                            nearestPrompt = prompt
                            nearestItem = meshPart
                            shortestDistance = distance
                        end
                    end
                end
            end
        end
    end
    
    return nearestPrompt, nearestItem
end

local function StartAutofarm()
    if isAutofarmEnabled then return end
    isAutofarmEnabled = true
    
    -- КРИТИЧНО: Обновляем _G переменные при запуске автофарма
    _G.YBAAutoFarmEnabled = true
    _G.YBAFarmItems = Settings.FarmItems
    
    -- КРИТИЧНО: Инициализируем счетчики ТОЛЬКО если они не существуют
    if not farmStats.startTime or farmStats.startTime == 0 then
        farmStats.itemsCollected = 0
        farmStats.itemsSold = 0
        farmStats.moneyCollected = 0
        farmStats.moneySold = 0
        farmStats.startTime = tick()
        print("[Autofarm] Счетчики инициализированы")
    else
        print("[Autofarm] Продолжение фарма. Собрано: " .. farmStats.itemsCollected .. ", Продано: " .. farmStats.itemsSold)
    end
    
    if not farmPlatform then
        CreateFarmPlatform()
    end
    
    if not isNoClipping then
        StartNoClip()
    end
    
    Library:Notify({
        Title = "Autofarm",
        Content = "Автофарм запущен! (Адаптивная скорость)",
        Duration = 3
    })
    
    local platformTimer = 0
    local onPlatform = false
    local platformPos = farmPlatform.Position
    local mapPatrolPoints = {
        Vector3.new(platformPos.X, -60, platformPos.Z),
        Vector3.new(32.29478073120117, -58.0815315246582, 418.4544982910156),
        Vector3.new(-449.7508544921875, -42.960453033447266, -205.11923217773438),
        Vector3.new(-17.46112632751465, -43.924129486083984, -744.8727416992188),
        Vector3.new(704.6179809570312, -83.0170669555664, -158.81675720214844)
    }
    
    local itemsCollected = 0
    local startTime = tick()
    
    task.spawn(function()
        while isAutofarmEnabled do
            local character = Player.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local rootPart = character.HumanoidRootPart
                local prompt, item = FindNearestItem()
                
                if prompt and item then
                    platformTimer = 0
                    onPlatform = false
                    
                    -- Проверка на застревание
                    if isPlayerStuck() then
                        Library:Notify({
                            Title = "Autofarm",
                            Content = "Обнаружено застревание! Возврат на платформу...",
                            Duration = 3
                        })
                        TeleportToPlatform()
                        stuckCounter = 0
                        task.wait(1)
                    end
                    
                    local itemName = prompt.ObjectText or "Unknown"
                    
                    -- КРИТИЧНО: Настройка промпта для автоматического подбора (БЕЗ КАМЕРЫ)
                    prompt.MaxActivationDistance = 100
                    prompt.RequiresLineOfSight = false
                    prompt.HoldDuration = 0
                    prompt.Enabled = true
                    prompt.ClickablePrompt = false
                    
                    -- ВАЖНО: Принудительно делаем промпт видимым (обход бага Roblox)
                    prompt.Style = Enum.ProximityPromptStyle.Default
                    prompt.UIOffset = Vector2.new(0, 0)
                    
                    local targetPos = item.Position + Vector3.new(0, -8, 0)
                    
                    -- БЫСТРАЯ телепортация к предмету
                    bypassTeleport(targetPos)
                    
                    -- КРИТИЧНО: Создаем ЯКОРЬ для персонажа (BodyPosition + BodyGyro)
                    local bodyPos = Instance.new("BodyPosition")
                    bodyPos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bodyPos.Position = targetPos
                    bodyPos.P = 10000
                    bodyPos.D = 1000
                    bodyPos.Parent = rootPart
                    
                    local bodyGyro = Instance.new("BodyGyro")
                    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bodyGyro.CFrame = rootPart.CFrame
                    bodyGyro.P = 10000
                    bodyGyro.D = 1000
                    bodyGyro.Parent = rootPart
                    
                    -- Создаем временную невидимую платформу под персонажем
                    local tempPlatform = Instance.new("Part")
                    tempPlatform.Name = "TempPickupPlatform"
                    tempPlatform.Size = Vector3.new(10, 1, 10)
                    tempPlatform.Position = targetPos - Vector3.new(0, 3, 0)
                    tempPlatform.Anchored = true
                    tempPlatform.CanCollide = true
                    tempPlatform.Transparency = 1
                    tempPlatform.Parent = workspace
                    
                    -- ЖЕСТКАЯ фиксация позиции
                    rootPart.CFrame = CFrame.new(targetPos)
                    rootPart.Anchored = true  -- ЯКОРИМ персонажа!
                    
                    -- КРИТИЧНО: ПОВОРАЧИВАЕМ КАМЕРУ НА ПРЕДМЕТ!
                    local camera = workspace.CurrentCamera
                    local originalCameraCFrame = camera.CFrame
                    local originalCameraType = camera.CameraType
                    
                    -- Делаем камеру скриптовой и направляем на предмет
                    camera.CameraType = Enum.CameraType.Scriptable
                    local lookAtPos = item.Position
                    camera.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0), lookAtPos)
                    
                    -- Задержка для полной стабилизации
                    task.wait(0.1)
                    
                    -- КРИТИЧНО: Принудительно показываем промпт игроку
                    pcall(function()
                        prompt.Parent = item
                        prompt.Enabled = true
                        task.wait(0.01)
                    end)
                    
                    -- УМЕНЬШЕННОЕ количество попыток (было 50, теперь 10)
                    local maxAttempts = 10
                    local attempt = 0
                    local itemPickedUp = false
                    
                    while item:IsDescendantOf(workspace) and attempt < maxAttempts do
                        attempt = attempt + 1
                        
                        -- Каждую попытку направляем камеру на предмет
                        pcall(function()
                            if item and item:IsDescendantOf(workspace) then
                                camera.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0), item.Position)
                            end
                        end)
                        
                        -- Активация промпта (1 раз за попытку)
                        pcall(function() fireproximityprompt(prompt, 0, true) end)
                        
                        task.wait(0.05)  -- Задержка между попытками
                        
                        -- Проверяем подобрался ли предмет
                        if not item:IsDescendantOf(workspace) then
                            itemPickedUp = true
                            break
                        end
                    end
                    
                    -- ВОЗВРАЩАЕМ КАМЕРУ ОБРАТНО (КРИТИЧНО!)
                    pcall(function()
                        camera.CameraType = originalCameraType
                    end)
                    
                    -- РАЗЯКОРИВАЕМ персонажа
                    rootPart.Anchored = false
                    
                    -- Удаляем BodyPosition и BodyGyro
                    pcall(function() bodyPos:Destroy() end)
                    pcall(function() bodyGyro:Destroy() end)
                    
                    -- Удаляем временную платформу
                    pcall(function() tempPlatform:Destroy() end)
                    
                    -- ЗАДЕРЖКА ПОСЛЕ ПОДБОРА (защита от кика)
                    if itemPickedUp then
                        -- КРИТИЧНО: Увеличиваем счетчики СРАЗУ после подбора
                        local itemPrice = itemPrices[itemName] or 0
                        
                        farmStats.itemsCollected = (farmStats.itemsCollected or 0) + 1
                        farmStats.moneyCollected = (farmStats.moneyCollected or 0) + itemPrice
                        
                        -- КРИТИЧНО: Сохраняем в _G для сохранения между сессиями
                        _G.YBAItemsCollected = farmStats.itemsCollected
                        _G.YBAMoneyCollected = farmStats.moneyCollected
                        
                        -- УБРАНО: Спам логов и уведомлений
                        
                        task.wait(0.3)  -- 300мс задержка после успешного подбора
                    else
                        -- Предмет НЕ подобрался (без спама)
                        task.wait(0.5)  -- 500мс если не подобрали (больше задержка)
                    end
                elseif not prompt and not item then
                    if farmPlatform then
                        local platformPos = farmPlatform.Position
                        local distX = math.abs(rootPart.Position.X - platformPos.X)
                        local distZ = math.abs(rootPart.Position.Z - platformPos.Z)
                        local distY = math.abs(rootPart.Position.Y - platformPos.Y)
                        
                        if distX <= 30 and distZ <= 30 and distY <= 10 then
                            if not onPlatform then
                                onPlatform = true
                                platformTimer = tick()
                            elseif tick() - platformTimer >= 15 then
                                Library:Notify({
                                    Title = "Autofarm",
                                    Content = "Патрулирование карты...",
                                    Duration = 2
                                })
                                
                                for _, patrolPos in ipairs(mapPatrolPoints) do
                                    if not isAutofarmEnabled then break end
                                    bypassTeleport(patrolPos)
                                    task.wait(0.3)
                                    local newPrompt, newItem = FindNearestItem()
                                    if newPrompt and newItem then
                                        break
                                    end
                                end
                                platformTimer = tick()
                            end
                        else
                            platformTimer = 0
                            onPlatform = false
                            if distX > 30 or distZ > 30 or distY > 10 then
                                TeleportToPlatform()
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end
            task.wait(0.1)
        end
    end)
end

