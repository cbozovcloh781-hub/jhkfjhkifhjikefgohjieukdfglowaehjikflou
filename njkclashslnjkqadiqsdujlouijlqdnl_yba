StartMoneyFarm = function()
    if moneyFarmThread then return end
    isMoneyFarmEnabled = true
    
    pcall(function()
        if Window and Window.Notify then
            Window:Notify({
                Title = "Money Farm",
                Content = "Money monitoring started! Limit: $1,000,000",
                Duration = 3
            })
        end
    end)
    
    moneyFarmThread = task.spawn(function()
        while isMoneyFarmEnabled do
            local money = GetPlayerMoney()
            currentMoney = money
            
            if money >= Settings.MoneyLimit then
                if tick() - lastMillionNotification >= 300 then
                    pcall(function()
                        if Window and Window.Notify then
                            Window:Notify({
                                Title = "Money Farm",
                                Content = "Balance reached $" .. Settings.MoneyLimit .. "! Consider selling items.",
                                Duration = 5
                            })
                        end
                    end)
                    
                    pcall(function()
