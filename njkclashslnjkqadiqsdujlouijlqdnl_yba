    local prestige = 0
    local prestigeCheckAttempts = 0
    local maxPrestigeChecks = 10
    
    while prestigeCheckAttempts < maxPrestigeChecks do
        prestigeCheckAttempts = prestigeCheckAttempts + 1
        
