if DrawingSupported then
    globalConnections.espUpdate = RunService.RenderStepped:Connect(function()
        if not ESPSettings.Enabled then DisableESP() return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not Drawings.ESP[player] then CreateESP(player) end
                UpdateESP(player)
            end
        end
    end)
end

