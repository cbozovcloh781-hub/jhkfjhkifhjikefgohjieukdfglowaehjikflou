    end
    
    print("[YBA Enhanced] LoadingScreen обнаружен! Ожидание кнопки Play...")
    
    -- Ждем появления структуры
    local frames = loadingScreen:WaitForChild("Frames", 10)
    if not frames then return end
    
    local playButton = nil
    local buttonPath = ""
    
