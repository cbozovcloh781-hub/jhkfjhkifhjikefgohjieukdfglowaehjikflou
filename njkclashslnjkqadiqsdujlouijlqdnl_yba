        queueteleport([[loadstring(game:HttpGet("]] .. scriptURL .. [["))()]])
        
        Library:Notify({
            Title = "Автозагрузка",
            Content = "Скрипт загрузится автоматически после телепорта!",
            Duration = 3
        })
    else
        print("[YBA Enhanced] queue_on_teleport НЕ поддерживается. Используй autoloader.")
        Library:Notify({
            Title = "Внимание",
            Content = "Используй autoloader для автозагрузки!",
            Duration = 5
        })
    end
    
    -- НОВОЕ: Retry логика с автоматическим поиском нового сервера при GameFull
    local maxRetries = 10
    local retryCount = 0
    local teleportSuccess = false
    
    while retryCount < maxRetries and not teleportSuccess do
        retryCount = retryCount + 1
        
        local success, result = pcall(function()
            -- Улучшенный поиск серверов (как в Infinite Yield)
            local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"))
            
            if servers and servers.data then
                local currentServerId = game.JobId
                local availableServers = {}
                
                for _, server in pairs(servers.data) do
                    if type(server) == "table" and tonumber(server.playing) and tonumber(server.maxPlayers) and server.playing < server.maxPlayers and server.id ~= currentServerId then
                        table.insert(availableServers, 1, server.id)
                    end
                end
                
                if #availableServers > 0 then
                    local randomServer = availableServers[math.random(1, #availableServers)]
                    
                    print("[YBA Enhanced] Попытка " .. retryCount .. "/" .. maxRetries)
                    print("[YBA Enhanced] Найдено серверов: " .. #availableServers)
                    print("[YBA Enhanced] Телепорт на сервер: " .. randomServer)
                    
                    -- НОВОЕ: Используем TeleportAsync с обработкой ошибок
                    local teleportOptions = Instance.new("TeleportOptions")
                    teleportOptions.ShouldReserveServer = false
                    
                    local teleportAttempt = 0
                    local teleportError = nil
                    
                    -- Пытаемся телепортироваться с обработкой GameFull
                    while teleportAttempt < 3 do
                        teleportAttempt = teleportAttempt + 1
                        
                        local teleportSuccess, teleportResult = pcall(function()
                            TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer, Player, nil, teleportOptions)
                        end)
                        
                        if teleportSuccess then
                            print("[YBA Enhanced] Телепорт успешен!")
                            return true
                        else
                            teleportError = tostring(teleportResult)
                            print("[YBA Enhanced] Ошибка телепорта (попытка " .. teleportAttempt .. "/3): " .. teleportError)
                            
                            -- Если сервер полный - пробуем другой сервер
                            if teleportError:find("GameFull") or teleportError:find("full") then
                                print("[YBA Enhanced] Сервер полный! Ищем другой сервер...")
                                Library:Notify({
                                    Title = "Свап сервера",
                                    Content = "Сервер полный! Попытка " .. retryCount .. "/" .. maxRetries,
                                    Duration = 2
                                })
                                break  -- Выходим из внутреннего цикла и ищем новый сервер
                            else
                                -- Другая ошибка - ждем и пробуем снова
                                task.wait(1)
                            end
                        end
                    end
                    
                    -- Если все 3 попытки неудачны - пробуем другой сервер
                    if teleportError then
                        return false
                    end
                else
                    print("[YBA Enhanced] Нет доступных серверов")
                    Library:Notify({
                        Title = "Ошибка",
                        Content = "Не найдено доступных серверов",
                        Duration = 5
                    })
                    return false
                end
            end
        end)
        
        if success and result then
            teleportSuccess = true
            break
        else
            print("[YBA Enhanced] Попытка " .. retryCount .. " неудачна. Ищем другой сервер...")
            task.wait(2)  -- Задержка перед следующей попыткой
        end
    end
    
    if not teleportSuccess then
        Library:Notify({
            Title = "Ошибка свапа",
            Content = "Не удалось найти доступный сервер за " .. maxRetries .. " попыток",
            Duration = 5
        })
        print("[YBA Enhanced] КРИТИЧЕСКАЯ ОШИБКА: Не удалось сменить сервер за " .. maxRetries .. " попыток")
    end
end

-- Cheater Detection System
local playerPositions = {}
local cheaterDetections = {}  -- {userId = {count = число, lastWarning = время}}
local detectedCheatersCount = 0
local cheaterDetectionEnabled = false
local detectedCheaters = {}  -- НОВОЕ: Список обнаруженных читеров

local function StartCheaterDetection()
    if cheaterDetectionEnabled then return end
    cheaterDetectionEnabled = true
    
    -- КРИТИЧНО: Обновляем _G переменную при запуске детектора
    _G.YBAAutoServerHop = true
    
    Library:Notify({
        Title = "Детектор читеров",
        Content = "Система обнаружения читеров активирована",
        Duration = 3
    })
    
    -- НОВОЕ: Поток для очистки старых варнингов (каждые 10 секунд)
    task.spawn(function()
        while cheaterDetectionEnabled and Settings.AutoServerHop do
            local currentTime = tick()
            local warningTimeout = 60  -- 60 секунд без нарушений = сброс варнингов
            
            for userId, data in pairs(cheaterDetections) do
                if data.lastWarning and (currentTime - data.lastWarning) >= warningTimeout then
                    -- Прошло 60 секунд без новых нарушений - сбрасываем варнинги
                    local oldCount = data.count or 0
                    cheaterDetections[userId] = nil
                    
                    if Settings.DebugMode and oldCount > 0 then
                        local player = Players:GetPlayerByUserId(userId)
                        if player then
                            print("[Cheater Detection] Варнинги сброшены для " .. player.Name .. " (было: " .. oldCount .. ")")
                        end
                    end
                end
            end
            
            task.wait(10)  -- Проверяем каждые 10 секунд
        end
    end)
    
    task.spawn(function()
        while cheaterDetectionEnabled and Settings.AutoServerHop do
            -- НОВОЕ: Проверка на AFK фармеров возле крана
            local craneBox = nil
            pcall(function()
                craneBox = workspace.Map.Prison.Prison_Props.Prison_Crane2.Prison_Crane1_CraneBox
            end)
            
            if craneBox then
                local afkFarmersCount = 0
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (player.Character.HumanoidRootPart.Position - craneBox.Position).Magnitude
                        
                        -- Если игрок ближе 20 стадов к крану = AFK фармер
                        if distance < 20 then
                            afkFarmersCount = afkFarmersCount + 1
                            
                            if Settings.DebugMode then
                                print("[Cheater Detection] AFK фармер обнаружен: " .. player.Name .. " (расстояние: " .. math.floor(distance) .. " стадов)")
                            end
                        end
                    end
                end
                
                -- Если 2+ AFK фармеров = свапаем сервер
                if afkFarmersCount >= 2 then
                    Library:Notify({
                        Title = "Свап сервера",
                        Content = "Обнаружено " .. afkFarmersCount .. " AFK фармеров! Смена сервера через 3 секунды...",
                        Duration = 3
                    })
                    
                    if Settings.DebugMode then
                        print("[Cheater Detection] Обнаружено " .. afkFarmersCount .. " AFK фармеров возле крана. Свап сервера...")
                    end
                    
                    task.wait(3)
                    ServerHop()
                    return
                end
            end
            
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local currentPos = player.Character.HumanoidRootPart.Position
                    
                    if playerPositions[player.UserId] then
                        local lastPos = playerPositions[player.UserId].Position
                        local lastTime = playerPositions[player.UserId].Time
                        local currentTime = tick()
                        
                        local distance = (currentPos - lastPos).Magnitude
                        local timeDiff = currentTime - lastTime
                        
                        -- Если игрок переместился больше чем на 200 стадов за 0.5 секунды = читер
                        if timeDiff > 0.5 and timeDiff < 2 then
                            local speed = distance / timeDiff
                            
                            if speed > 400 then -- 400+ studs/sec = явный телепорт
                                -- ИСПРАВЛЕНО: Инициализируем структуру данных если её нет
                                if not cheaterDetections[player.UserId] then
                                    cheaterDetections[player.UserId] = {count = 0, lastWarning = currentTime}
                                end
                                
                                cheaterDetections[player.UserId].count = cheaterDetections[player.UserId].count + 1
                                cheaterDetections[player.UserId].lastWarning = currentTime  -- Обновляем время последнего нарушения
                                
                                local warningCount = cheaterDetections[player.UserId].count
                                
                                if warningCount >= Settings.CheaterDetectionSensitivity then
                                    detectedCheatersCount = detectedCheatersCount + 1
                                    
                                    -- НОВОЕ: Добавляем в список читеров
                                    detectedCheaters[player.UserId] = true
                                    
                                    Library:Notify({
                                        Title = "Читер обнаружен!",
                                        Content = player.Name .. " использует телепорт (" .. detectedCheatersCount .. "/3)",
                                        Duration = 5
                                    })
                                    
                                    cheaterDetections[player.UserId].count = 0  -- Сбрасываем счетчик после подтверждения
                                    
                                    if detectedCheatersCount >= 3 then
                                        Library:Notify({
                                            Title = "Свап сервера",
                                            Content = "Обнаружено 3 читера! Смена сервера через 3 секунды...",
                                            Duration = 3
                                        })
                                        
                                        task.wait(3)
                                        ServerHop()
                                        return
                                    end
                                elseif Settings.DebugMode then
                                    print("[Cheater Detection] " .. player.Name .. " подозрителен (" .. warningCount .. "/" .. Settings.CheaterDetectionSensitivity .. ") - скорость: " .. math.floor(speed) .. " стадов/сек")
                                end
                            end
                        end
                    end
                    
                    playerPositions[player.UserId] = {
                        Position = currentPos,
                        Time = tick()
                    }
                end
            end
            
            task.wait(0.5)
        end
    end)
end

