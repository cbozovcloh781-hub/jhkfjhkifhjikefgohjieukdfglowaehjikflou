-- КРИТИЧНО: Функция сохранения ПОЛНОГО конфига на сервер
local function SaveConfigToServer()
    pcall(function()
        local HttpService = game:GetService("HttpService")
        
        -- Конвертируем дропдауны в массивы
        local farm_items = {}
        for item, enabled in pairs(Settings.FarmItems or {}) do
            if enabled then table.insert(farm_items, item) end
        end
        
        local sell_items = {}
        for item, enabled in pairs(Settings.SellItems or {}) do
            if enabled then table.insert(sell_items, item) end
        end
        
        -- Конвертируем Color3 в RGB таблицы
        local function colorToRGB(color)
            return {R = math.floor(color.R * 255), G = math.floor(color.G * 255), B = math.floor(color.B * 255)}
