                    if not isNoClipping then
                        StartNoClip()
                    end
                    
                    -- КРИТИЧНО: Отключаем коллизии всех частей персонажа
                    pcall(function()
                        for _, part in pairs(character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end)
                    
                    while item:IsDescendantOf(workspace) and attempt < maxAttempts do
                        attempt = attempt + 1
                        
                        -- КРИТИЧНО: Удерживаем позицию через BodyVelocity
                        rootPart.CFrame = CFrame.new(pickupPosition)
                        bodyVel.Velocity = Vector3.new(0, 0, 0)
                        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                        
                        -- КРИТИЧНО: Постоянно отключаем коллизии
                        pcall(function()
                            for _, part in pairs(character:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    part.CanCollide = false
                                end
                            end
                        end)
                        
                        -- Обновляем камеру
                        pcall(function()
                            if item and item:IsDescendantOf(workspace) then
                                camera.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0), item.Position)
                            end
                        end)
                        
                        pcall(function() fireproximityprompt(prompt, 0, true) end)
                        
                        task.wait(0.05)
                        
                        -- КРИТИЧНО: Снова удерживаем позицию
                        rootPart.CFrame = CFrame.new(pickupPosition)
                        bodyVel.Velocity = Vector3.new(0, 0, 0)
                        
                        if not item:IsDescendantOf(workspace) then
                            itemPickedUp = true
                            break
                        end
                    
                        task.wait(0.1)
                    end
                    
                    -- Возвращаем камеру
                    pcall(function()
                        camera.CameraType = originalCameraType
                        camera.CFrame = originalCameraCFrame
                    end)
                    
                    -- КРИТИЧНО: Еще раз отключаем коллизии перед финальным удержанием
                    pcall(function()
                        for _, part in pairs(character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end)
                    
                    task.wait(0.1)
                    
                    -- КРИТИЧНО: Финальное удержание позиции перед разблокировкой
                    rootPart.CFrame = CFrame.new(pickupPosition)
                    bodyVel.Velocity = Vector3.new(0, 0, 0)
                    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    
                    task.wait(0.2)
                    
                    -- КРИТИЧНО: Удаляем BodyVelocity ТОЛЬКО ПОСЛЕ всех попыток
                    pcall(function() bodyVel:Destroy() end)
                    
                    pcall(function() tempPlatform:Destroy() end)
                    
                    if itemPickedUp then
                        local itemPrice = itemPrices[itemName] or 0
                        
                        farmStats.itemsCollected = (farmStats.itemsCollected or 0) + 1
                        farmStats.moneyCollected = (farmStats.moneyCollected or 0) + itemPrice
                        
                        _G.YBAItemsCollected = farmStats.itemsCollected
                        _G.YBAMoneyCollected = farmStats.moneyCollected
                        
                        task.wait(Settings.FarmDelay or 0.5)
                    else
                        task.wait(0.8)
                    end
                elseif not prompt and not item then
                    -- Сразу начинаем патрулирование по координатам спавна
                    isPatrolling = true
                    
                    -- Создаём таблицу посещённых точек
                    local visitedPoints = {}
                    local pointsChecked = 0
                    local totalPoints = #itemSpawnPoints
                    
                    while isPatrolling and isAutofarmEnabled and pointsChecked < totalPoints do
                        -- КРИТИЧНО: Проверяем появился ли предмет ПЕРЕД телепортом
                        local checkPrompt, checkItem = FindNearestItem()
                        if checkPrompt and checkItem then
                            isPatrolling = false
                            break
                        end
                        
                        -- Находим ближайшую непосещённую точку
                        local currentPos = rootPart.Position
                        local spawnPoint, spawnIndex = findNearestUnvisitedPoint(currentPos, visitedPoints)
                        
                        if not spawnPoint then
                            -- Все точки проверены, начинаем сначала
                            visitedPoints = {}
                            pointsChecked = 0
                            spawnPoint, spawnIndex = findNearestUnvisitedPoint(currentPos, visitedPoints)
                        end
                        
                        if spawnPoint and spawnIndex then
                            -- КРИТИЧНО: Проверяем появился ли предмет ПЕРЕД телепортом
                            local checkPrompt, checkItem = FindNearestItem()
                            if checkPrompt and checkItem then
                                isPatrolling = false
                                break
                            end
                            
                            -- Отмечаем точку как посещённую
                            visitedPoints[spawnIndex] = true
                            pointsChecked = pointsChecked + 1
                        
                        -- Телепортируемся на 8 единиц ниже точки спавна
                        local targetPos = spawnPoint.Position - Vector3.new(0, 8, 0)
                        bypassTeleport(targetPos)
                        
                        -- Создаём BodyVelocity для фиксации позиции
                        local bodyVel = Instance.new("BodyVelocity")
                        bodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                        bodyVel.Velocity = Vector3.new(0, 0, 0)
                        bodyVel.Parent = rootPart
                        
                        rootPart.CFrame = CFrame.new(targetPos)
                        rootPart.Anchored = false
                        
                        task.wait(0.3)
                        
                        -- Проверяем ВСЕ предметы в радиусе если включен режим All
                        local selectedItems = Settings.FarmItems
                        if Options and Options.FarmItems and Options.FarmItems.Value then
                            selectedItems = Options.FarmItems.Value
                        end
                        
                        local isAllMode = false
                        if type(selectedItems) == "table" then
                            for selectedItem, isSelected in pairs(selectedItems) do
                                if isSelected and selectedItem == "All" then
                                    isAllMode = true
                                    break
                                end
                            end
                        end
                        
                        -- Собираем ВСЕ предметы на карте если режим All
                        local itemsFound = false
                        if isAllMode then
                            local itemSpawns = workspace:FindFirstChild("Item_Spawns")
                            if itemSpawns then
                                local itemsFolder = itemSpawns:FindFirstChild("Items")
                                if itemsFolder then
                                    -- Собираем список ВСЕХ предметов на карте
                                    local allItems = {}
                                    for _, itemModel in pairs(itemsFolder:GetChildren()) do
                                        if itemModel:IsA("Model") then
                                            local meshPart = itemModel:FindFirstChild("MeshPart")
                                            if meshPart and meshPart:FindFirstChild("PointLight") then
                                                local itemPrompt = itemModel:FindFirstChildOfClass("ProximityPrompt")
                                                if itemPrompt then
                                                    table.insert(allItems, {mesh = meshPart, prompt = itemPrompt})
                                                end
                                            end
                                        end
                                    end
                                    
                                    -- Телепортируемся к каждому предмету и подбираем
                                    for _, itemData in ipairs(allItems) do
                                        if not isAutofarmEnabled then break end
                                        
                                        local meshPart = itemData.mesh
                                        local itemPrompt = itemData.prompt
                                        
                                        if meshPart:IsDescendantOf(workspace) then
                                            itemsFound = true
                                            
                                            local itemPos = meshPart.Position
                                            
                                            -- Проверяем новая ли координата
                                            if isNewCoordinate(itemPos) then
                                                local itemName = itemPrompt.ObjectText or "Unknown"
                                                sendNewCoordinate(itemPos, itemName)
                                                
                                                pcall(function()
                                                    if Window and Window.Notify then
                                                        Window:Notify({
                                                            Title = "🎯 Новая точка!",
                                                            Content = itemName .. " на новой координате!",
                                                            Duration = 3
                                                        })
                                                    end
                                                end)
                                            end
                                            
                                            -- Телепортируемся на 8 единиц ниже предмета
                                            local itemTargetPos = itemPos - Vector3.new(0, 8, 0)
                                            bypassTeleport(itemTargetPos)
                                            
                                            -- Удаляем старый BodyVelocity
                                            pcall(function() bodyVel:Destroy() end)
                                            
                                            -- Создаём новый BodyVelocity
                                            bodyVel = Instance.new("BodyVelocity")
                                            bodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                                            bodyVel.Velocity = Vector3.new(0, 0, 0)
                                            bodyVel.Parent = rootPart
                                            
                                            rootPart.CFrame = CFrame.new(itemTargetPos)
                                            rootPart.Anchored = false
                                            
                                            task.wait(0.1)
                                            
                                            -- Настраиваем промпт
                                            itemPrompt.MaxActivationDistance = 100
                                            itemPrompt.RequiresLineOfSight = false
                                            itemPrompt.HoldDuration = 0
                                            itemPrompt.Enabled = true
                                            
                                            -- КРИТИЧНО: Настраиваем камеру на предмет
                                            local camera = workspace.CurrentCamera
                                            local originalCameraCFrame = camera.CFrame
                                            local originalCameraType = camera.CameraType
                                            
                                            camera.CameraType = Enum.CameraType.Scriptable
                                            camera.CFrame = CFrame.new(itemTargetPos + Vector3.new(0, 2, 0), meshPart.Position)
                                            
                                            -- Пытаемся подобрать
                                            local pickupAttempts = 0
                                            while meshPart:IsDescendantOf(workspace) and pickupAttempts < 5 and isAutofarmEnabled do
                                                pickupAttempts = pickupAttempts + 1
                                                
                                                -- КРИТИЧНО: Удерживаем позицию через BodyVelocity
                                                rootPart.CFrame = CFrame.new(itemTargetPos)
                                                bodyVel.Velocity = Vector3.new(0, 0, 0)
                                                rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                                rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                                
                                                -- Обновляем камеру
                                                pcall(function()
                                                    if meshPart and meshPart:IsDescendantOf(workspace) then
                                                        camera.CFrame = CFrame.new(itemTargetPos + Vector3.new(0, 2, 0), meshPart.Position)
                                                    end
                                                end)
                                                
                                                pcall(function() fireproximityprompt(itemPrompt, 0, true) end)
                                                task.wait(0.1)
                                            end
                                            
                                            -- Возвращаем камеру
                                            pcall(function()
                                                camera.CameraType = originalCameraType
                                                camera.CFrame = originalCameraCFrame
                                            end)
                                            
                                            if not meshPart:IsDescendantOf(workspace) then
                                                local itemName = itemPrompt.ObjectText or "Unknown"
                                                local itemPrice = itemPrices[itemName] or 0
                                                
                                                farmStats.itemsCollected = (farmStats.itemsCollected or 0) + 1
                                                farmStats.moneyCollected = (farmStats.moneyCollected or 0) + itemPrice
                                                
                                                _G.YBAItemsCollected = farmStats.itemsCollected
                                                _G.YBAMoneyCollected = farmStats.moneyCollected
                                            end
                                            
                                            task.wait(Settings.FarmDelay or 0.5)
                                        end
                                    end
                                end
                            end
                        else
                            -- Обычный режим - ищем ближайший нужный предмет
                            local newPrompt, newItem = FindNearestItem()
                            if newPrompt and newItem then
                                itemsFound = true
                                if bodyVel then
                                    pcall(function() bodyVel:Destroy() end)
                                end
                                break
                            end
                        end
                        
                        -- Удаляем BodyVelocity
                        if bodyVel then
                            pcall(function() bodyVel:Destroy() end)
                        end
                        
                        -- Если нашли предметы в режиме All, остаёмся на этой точке ещё немного
                        if itemsFound and isAllMode then
                            task.wait(0.5)
                        end
                        
                        -- Проверяем не появился ли нужный предмет рядом
                        if not isAllMode then
                            local newPrompt, newItem = FindNearestItem()
                            if newPrompt and newItem then
                                itemsFound = true
                                break
                            end
                        end
                        end
                    end
                    task.wait(0.1)
                end
            end
            task.wait(0.1)
        end
    end)
end

local function StopAutofarm()
    if not isAutofarmEnabled then return end
    
    isAutofarmEnabled = false
    
    if _G.YBAAutofarmThread then
        pcall(function()
            task.cancel(_G.YBAAutofarmThread)
        end)
        _G.YBAAutofarmThread = nil
    end
    
    _G.YBAAutoFarmEnabled = false
    
    -- КРИТИЧНО: ПОЛНЫЙ сброс переменных телепорта
    ResetTeleportVariables()
    
    pcall(function()
        if Window and Window.Notify then
            Window:Notify({
                Title = "Autofarm",
                Content = "Autofarm stopped - Teleport settings reset",
                Duration = 3
            })
        end
    end)
    
    if isNoClipping and not Settings.NoClip then
        StopNoClip()
    end
    
    pcall(function()
        local character = Player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local rootPart = character.HumanoidRootPart
            for _, obj in pairs(rootPart:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") or obj:IsA("BodyVelocity") then
                    obj:Destroy()
                end
            end
            rootPart.Anchored = false
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end)
    
    pcall(function()
        for _, obj in pairs(workspace:GetChildren()) do
            if obj.Name == "TempPickupPlatform" then
                obj:Destroy()
            end
        end
    end)
    
    for key, connection in pairs(autofarmConnections) do
        pcall(function()
            if typeof(connection) == "RBXScriptConnection" then
                connection:Disconnect()
            end
        end)
    end
    autofarmConnections = {}
end

-- Autosell Functions
local function SellItem(itemName)
    local character = Player.Character
    if not character then return false end
    
    if itemName == "Lucky Arrow" or itemName == "Lucky Stone Mask" then
        return false
    end
    
    local item = Player.Backpack:FindFirstChild(itemName)
    if not item then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:EquipTool(item)
        task.wait(0.05)
    end
    
    local remoteEvent = character:FindFirstChild("RemoteEvent")
    if remoteEvent then
        local args = {
            [1] = "EndDialogue",
            [2] = {
                ["NPC"] = "Merchant",
                ["Option"] = "Option2",
                ["Dialogue"] = "Dialogue5"
            }
        }
        remoteEvent:FireServer(table.unpack(args))
        return true
    end
    
    return false
end

function StartAutosell()
    if isAutosellEnabled then return end
    
    if not Settings.SellItems or not next(Settings.SellItems) then
        if _G.YBASellItems and next(_G.YBASellItems) then
            Settings.SellItems = _G.YBASellItems
            if Window and Window.Notify then
                Window:Notify({
                    Title = "Autosell",
                    Content = "Settings restored from _G",
                    Duration = 2
                })
            end
        else
            local configLoaded = LoadConfigFromServer()
            if not configLoaded or not Settings.SellItems or not next(Settings.SellItems) then
                if Window and Window.Notify then
                    Window:Notify({
                        Title = "Autosell",
                        Content = "ERROR: Failed to load settings!",
                        Duration = 5
                    })
                end
                return
            end
            if Window and Window.Notify then
                Window:Notify({
                    Title = "Autosell",
                    Content = "Settings loaded from server",
                    Duration = 2
                })
            end
        end
    end
    
    isAutosellEnabled = true
    
    _G.YBAAutoSellEnabled = true
    _G.YBASellItems = Settings.SellItems
    
    if Window and Window.Notify then
        Window:Notify({
            Title = "Autosell",
            Content = "Auto sell started! Limit: $1,000,000",
            Duration = 3
        })
    end
    
    task.spawn(function()
        while isAutosellEnabled do
            local selectedItems = Settings.SellItems
            if Options and Options.SellItems and Options.SellItems.Value then
                selectedItems = Options.SellItems.Value
            end
            
            if type(selectedItems) == "table" then
                local itemsSold = 0
                local itemsToSell = {}
                
                for _, item in pairs(Player.Backpack:GetChildren()) do
                    if item:IsA("Tool") then
                        local shouldSell = false
                        
                        for selectedItem, isSelected in pairs(selectedItems) do
                            if isSelected and (selectedItem == "All" or item.Name == selectedItem) then
                                shouldSell = true
                                break
                            end
                        end
                        
                        if shouldSell then
                            table.insert(itemsToSell, item.Name)
                        end
                    end
                end
                
                for _, itemName in ipairs(itemsToSell) do
                    if not isAutosellEnabled then break end
                    
                    local currentMoney = GetPlayerMoney()
                    
                    if currentMoney >= 1000000 then
                        pcall(function()
                            if Window and Window.Notify then
                                Window:Notify({
                                    Title = "Autosell",
                                    Content = "Balance reached limit $1,000,000! Autosell stopped.",
                                    Duration = 5
                                })
                            end
                        end)
                        
                        pcall(function()
                            local HttpService = game:GetService("HttpService")
                            local notificationData = {
                                action = "balance_limit_reached",
                                balance = currentMoney,
                                account = game.Players.LocalPlayer.Name,
                                server_id = game.JobId,
                                place_id = game.PlaceId,
                                timestamp = os.time()
                            }
                            
                            request({
                                Url = "http://localhost:5000/api/balance_alert",
                                Method = "POST",
                                Headers = {["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode(notificationData)
                            })
                        end)
                        
                        isAutosellEnabled = false
                        Settings.Autosell = false
                        _G.YBAAutoSellEnabled = false
                        
                        task.spawn(function()
                            while true do
                                task.wait(5)
                                local money = GetPlayerMoney()
                                if money < 1000000 then
                                    Window:Notify({
                                        Title = "Autosell",
                                        Content = "Balance dropped below $1,000,000. You can enable autosell again.",
                                        Duration = 5
                                    })
                                    break
                                end
                            end
                        end)
                        
                        break
                    end
                    
                    local itemPrice = itemPrices[itemName] or 0
                    
                    if currentMoney + itemPrice > 1000000 then
                        local cheapestItem = nil
                        local cheapestPrice = math.huge
                        
                        for _, checkItemName in ipairs(itemsToSell) do
                            local checkPrice = itemPrices[checkItemName] or 0
                            if checkPrice > 0 and checkPrice < cheapestPrice then
                                cheapestItem = checkItemName
                                cheapestPrice = checkPrice
                            end
                        end
                        
                        if itemName == cheapestItem then
                            pcall(function()
                                if Window and Window.Notify then
                                    Window:Notify({
                                        Title = "Autosell",
                                        Content = "Selling " .. itemName .. " (cheapest) to free up space",
                                        Duration = 3
                                    })
                                end
                            end)
                        else
                            itemName = nil
                        end
                    end
                    
                    if itemName and SellItem(itemName) then
                        itemsSold = itemsSold + 1
                        farmStats.itemsSold = (farmStats.itemsSold or 0) + 1
                        farmStats.moneySold = (farmStats.moneySold or 0) + itemPrice
                        
                        _G.YBAItemsSold = farmStats.itemsSold
                        _G.YBAMoneySold = farmStats.moneySold
                    end
                    task.wait(0.05)
                end
            end
            
            task.wait(0.5)
        end
    end)
end

local function StopAutosell()
    if not isAutosellEnabled then return end
    isAutosellEnabled = false
    
    _G.YBAAutoSellEnabled = false
    
    for _, connection in pairs(autosellConnections) do
