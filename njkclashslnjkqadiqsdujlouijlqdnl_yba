-- НОВОЕ: Функция для маркировки читеров в табе игроков
local function UpdatePlayerlistCheaterTags()
    if cheaterViewThread then
        pcall(function() task.cancel(cheaterViewThread) end)
        cheaterViewThread = nil
    end
    
    cheaterViewThread = task.spawn(function()
        while cheaterViewEnabled do
            pcall(function()
                local playerGui = Player.PlayerGui
                local hud = playerGui:FindFirstChild("HUD")
                if hud then
                    local playerlist = hud:FindFirstChild("Playerlist")
                    if playerlist then
                        -- Проходим по всем игрокам в табе
                        for _, playerFrame in pairs(playerlist:GetChildren()) do
                            if playerFrame:IsA("Frame") or playerFrame:IsA("GuiObject") then
                                local playerNameLabel = playerFrame:FindFirstChild("PlayerName")
                                if playerNameLabel and playerNameLabel:IsA("TextLabel") then
                                    -- Находим игрока по имени
                                    local playerName = playerNameLabel.Text:gsub("%[CHEATER%] ", "") -- Убираем старую метку
                                    local targetPlayer = Players:FindFirstChild(playerName)
                                    
                                    -- ИСПРАВЛЕНО: Проверяем И detectedCheaters И cheaterTimers
                                    local isCheater = false
                                    if targetPlayer then
                                        -- Читер если он в detectedCheaters ИЛИ в cheaterTimers (еще не истекло 60 секунд)
                                        if detectedCheaters[targetPlayer.UserId] or cheaterTimers[targetPlayer.UserId] then
                                            isCheater = true
                                        end
                                    end
                                    
                                    if isCheater then
                                        -- Помечаем читера
                                        if not playerNameLabel.Text:find("%[CHEATER%]") then
                                            playerNameLabel.Text = "[CHEATER] " .. playerName
                                            playerNameLabel.TextColor3 = Color3.fromRGB(255, 165, 0) -- Оранжевый
                                        end
                                    else
                                        -- Убираем метку ТОЛЬКО если игрок точно не читер
                                        if playerNameLabel.Text:find("%[CHEATER%]") then
                                            playerNameLabel.Text = playerName
                                            playerNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Белый
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait(1)
        end
        cheaterViewThread = nil
    end)
end

