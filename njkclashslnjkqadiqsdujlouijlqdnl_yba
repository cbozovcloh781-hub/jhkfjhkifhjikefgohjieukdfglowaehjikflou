-- Hook into game logs
local LogService = game:GetService("LogService")
local ScriptContext = game:GetService("ScriptContext")

LogService.MessageOut:Connect(function(message, messageType)
    if not consoleEnabled then return end
    
    local color = Color3.fromRGB(255, 255, 255)
    if messageType == Enum.MessageType.MessageError then
        color = Color3.fromRGB(255, 0, 0)
    elseif messageType == Enum.MessageType.MessageWarning then
        color = Color3.fromRGB(255, 255, 0)
    elseif messageType == Enum.MessageType.MessageInfo then
        color = Color3.fromRGB(0, 200, 255)
    end
    
    Console.AddLog(message, color)
end)

ScriptContext.Error:Connect(function(message, stack, script)
    if not consoleEnabled then return end
    Console.AddLog("ERROR: " .. message, Color3.fromRGB(255, 0, 0))
    if stack and stack ~= "" then
        Console.AddLog("Stack: " .. stack, Color3.fromRGB(200, 100, 100))
    end
end)



local consoleEnabled = false

local function StartConsole()
    if consoleEnabled then return end
    consoleEnabled = true
    
    pcall(function()
        if Console and Console.Create then
            Console.Create()
        end
    end)
end

local function StopConsole()
    if not consoleEnabled then return end
    consoleEnabled = false
    
    pcall(function()
        if Console and Console.Destroy then
            Console.Destroy()
        end
    end)
end

