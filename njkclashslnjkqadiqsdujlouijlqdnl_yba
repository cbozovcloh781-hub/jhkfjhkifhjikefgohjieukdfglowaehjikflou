local function HandleScriptError(errorMsg)
    -- Remove loading screen
    pcall(function()
        local coreGui = game:GetService("CoreGui")
        local loadingGui = coreGui:FindFirstChild("SsolyLoading")
        if loadingGui then loadingGui:Destroy() end
        
        local lighting = game:GetService("Lighting")
        local loadingBlur = lighting:FindFirstChild("SsolyLoadingBlur")
        if loadingBlur then loadingBlur:Destroy() end
    end)
    
    -- Show error notification
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Script Error",
            Text = "Failed to load script. Check console for details.",
            Duration = 10
        })
    end)
    
    error("[YBA Enhanced] Script failed to load: " .. tostring(errorMsg))
end

