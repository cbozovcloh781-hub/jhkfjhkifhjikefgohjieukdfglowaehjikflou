-- Command Handler for Telegram bot
local commandHandlerEnabled = false

local function ExecuteCommand(command, args)
    if command == "toggle_autofarm" then
        if not isAutofarmEnabled then
            Settings.Autofarm = true
            if Options and Options.Autofarm then
                pcall(function()
                    Options.Autofarm:SetValue(true)
                end)
            end
            StartAutofarm()
            return {success = true, message = "Autofarm enabled"}
        else
            Settings.Autofarm = false
            if Options and Options.Autofarm then
                pcall(function()
                    Options.Autofarm:SetValue(false)
                end)
            end
            StopAutofarm()
            return {success = true, message = "Autofarm disabled"}
        end
    elseif command == "toggle_autosell" then
        if not isAutosellEnabled then
            Settings.Autosell = true
            if Options and Options.Autosell then
                Options.Autosell:SetValue(true)
            end
            StartAutosell()
            return {success = true, message = "Autosell enabled"}
        else
            Settings.Autosell = false
            if Options and Options.Autosell then
                pcall(function()
                    Options.Autosell:SetValue(false)
                end)
            end
            StopAutosell()
            return {success = true, message = "Autosell disabled"}
        end
    elseif command == "server_hop" then
        ServerHop()
        return {success = true, message = "Server hopping..."}
    elseif command == "get_stats" then
        local money = GetPlayerMoney()
        local uptime = math.floor(tick() - farmStats.startTime)
        
        local totalItems = 0
        local sellableItems = 0
        local sellableValue = 0
        local luckyArrows = 0
        local luckyMasks = 0
        
        for _, item in pairs(Player.Backpack:GetChildren()) do
            if item:IsA("Tool") then
                totalItems = totalItems + 1
                
                if item.Name == "Lucky Arrow" then
                    luckyArrows = luckyArrows + 1
                elseif item.Name == "Lucky Stone Mask" then
                    luckyMasks = luckyMasks + 1
                end
                
                local itemPrice = itemPrices[item.Name] or 0
                if itemPrice > 0 and item.Name ~= "Lucky Arrow" and item.Name ~= "Lucky Stone Mask" then
                    sellableItems = sellableItems + 1
                    sellableValue = sellableValue + itemPrice
                end
            end
        end
        
        local statsData = {
            balance = money,
            uptime = uptime,
            items_collected = farmStats.itemsCollected,
            items_sold = farmStats.itemsSold,
            money_collected = farmStats.moneyCollected,
            money_sold = farmStats.moneySold,
            autofarm_status = isAutofarmEnabled,
            autosell_status = isAutosellEnabled,
            inventory_total = totalItems,
            inventory_sellable = sellableItems,
            inventory_sellable_value = sellableValue,
            lucky_arrows = luckyArrows,
            lucky_masks = luckyMasks,
            current_account = game.Players.LocalPlayer.Name,
            server_hops = farmStats.serverHops or 0
        }
        
        local HttpService = game:GetService("HttpService")
        pcall(function()
            request({
                Url = "http://localhost:5000/api/stats/saved",
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(statsData)
            })
        end)
        
        return {success = true, message = "Statistics sent", data = statsData}
    else
        return {success = false, message = "Unknown command: " .. command}
    end
end

local function StartCommandHandler()
    if commandHandlerEnabled then return end
    commandHandlerEnabled = true
    
    -- Auto-send stats every 5 seconds
    task.spawn(function()
        while commandHandlerEnabled do
            local success, err = pcall(function()
                local money = GetPlayerMoney()
                local uptime = math.floor(tick() - farmStats.startTime)
                
                local totalItems = 0
                local sellableItems = 0
                local sellableValue = 0
                local luckyArrows = 0
                local luckyMasks = 0
                
                for _, item in pairs(Player.Backpack:GetChildren()) do
                    if item:IsA("Tool") then
                        totalItems = totalItems + 1
                        
                        if item.Name == "Lucky Arrow" then
                            luckyArrows = luckyArrows + 1
                        elseif item.Name == "Lucky Stone Mask" then
                            luckyMasks = luckyMasks + 1
                        end
                        
                        local itemPrice = itemPrices[item.Name] or 0
                        if itemPrice > 0 and item.Name ~= "Lucky Arrow" and item.Name ~= "Lucky Stone Mask" then
                            sellableItems = sellableItems + 1
                            sellableValue = sellableValue + itemPrice
                        end
                    end
                end
                
                local itemsCollectedDelta = farmStats.itemsCollected - farmStats.prevItemsCollected
                local itemsSoldDelta = farmStats.itemsSold - farmStats.prevItemsSold
                local moneyCollectedDelta = farmStats.moneyCollected - farmStats.prevMoneyCollected
                local moneySoldDelta = farmStats.moneySold - farmStats.prevMoneySold
                
                farmStats.prevItemsCollected = farmStats.itemsCollected
                farmStats.prevItemsSold = farmStats.itemsSold
                farmStats.prevMoneyCollected = farmStats.moneyCollected
                farmStats.prevMoneySold = farmStats.moneySold
                
                local statsData = {
                    balance = money,
                    uptime = uptime,
                    items_collected = farmStats.itemsCollected,
                    items_sold = farmStats.itemsSold,
                    money_collected = farmStats.moneyCollected,
                    money_sold = farmStats.moneySold,
                    autofarm_status = isAutofarmEnabled,
                    autosell_status = isAutosellEnabled,
                    inventory_total = totalItems,
                    inventory_sellable = sellableItems,
                    inventory_sellable_value = sellableValue,
                    lucky_arrows = luckyArrows,
                    lucky_masks = luckyMasks,
                    current_account = game.Players.LocalPlayer.Name,
                    server_hops = farmStats.serverHops or 0,
                    items_collected_delta = itemsCollectedDelta,
                    items_sold_delta = itemsSoldDelta,
                    money_collected_delta = moneyCollectedDelta,
                    money_sold_delta = moneySoldDelta
                }
                
                local HttpService = game:GetService("HttpService")
                request({
                    Url = "http://localhost:5000/api/stats",
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(statsData)
                })
            end)
            
            task.wait(5)
        end
    end)
    
    task.spawn(function()
        while commandHandlerEnabled do
            local success, result = pcall(function()
                local response = request({
                    Url = "http://localhost:5000/api/command",
                    Method = "GET"
                })
                
                if response.StatusCode == 200 then
                    local HttpService = game:GetService("HttpService")
                    local data = HttpService:JSONDecode(response.Body)
                    
                    if data.command then
                        ExecuteCommand(data.command)
                    end
                end
            end)
            
            task.wait(1)
        end
    end)
end

StartCommandHandler()

-- Cleanup function
local function DestroyAllFunctions()
    ScriptDestroyed = true
    
    pcall(function() if isFlying then StopFly() end end)
    pcall(function() if isNoClipping then StopNoClip() end end)
    pcall(function() if isSpeedHacking then StopSpeed() end end)
    pcall(function() if isInfiniteJumping then StopInfiniteJump() end end)
    pcall(function() if isJumpHacking then StopJumpHack() end end)
    
    pcall(function() if isAutofarmEnabled then StopAutofarm() end end)
    pcall(function() if isAutosellEnabled then StopAutosell() end end)
    pcall(function() if isAutobuyEnabled then StopAutobuy() end end)
    
    pcall(function() if antiAFKEnabled then StopAntiAFK() end end)
    pcall(function() if isMoneyFarmEnabled then StopMoneyFarm() end end)
    pcall(function() if consoleEnabled then StopConsole() end end)
    pcall(function() if commandHandlerEnabled then commandHandlerEnabled = false end end)
    pcall(function() if isZoomUnlocked then StopUnlockZoom() end end)
    pcall(function() if cheaterDetectionEnabled then StopCheaterDetection() end end)
    
    pcall(function()
        local character = Player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local rootPart = character.HumanoidRootPart
            for _, obj in pairs(rootPart:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") or obj:IsA("BodyVelocity") or obj:IsA("BodyAngularVelocity") then
                    obj:Destroy()
                end
            end
            rootPart.Anchored = false
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end)
    
    pcall(function()
        for _, obj in pairs(workspace:GetChildren()) do
            if obj.Name == "TempPickupPlatform" then
                obj:Destroy()
            end
        end
    end)
    
    pcall(function()
        ESPSettings.Enabled = false
        CleanupESP()
    end)
    
    -- Очистка Cheater View
    pcall(function() 
        cheaterViewEnabled = false
        if cheaterViewThread then task.cancel(cheaterViewThread) cheaterViewThread = nil end
        if cheaterDetectionThread then task.cancel(cheaterDetectionThread) cheaterDetectionThread = nil end
        ClearAllCheaterTags()
    end)
    
    -- Отключаем все глобальные соединения
    for _, connection in pairs(globalConnections) do
        pcall(function()
            if typeof(connection) == "RBXScriptConnection" then
                connection:Disconnect()
            elseif typeof(connection) == "thread" then
                task.cancel(connection)
            end
        end)
    end
    globalConnections = {}
    
    -- Удаляем платформу
    pcall(function()
        DestroyFarmPlatform()
    end)
    
    -- Удаляем UI
    pcall(function()
        if Window and Window.Destroy then
            Window:Destroy()
        end
    end)
    
    -- Очищаем все настройки чтобы предотвратить автозапуск
    Settings.Fly = false
    Settings.NoClip = false
    Settings.Speed = false
    Settings.InfiniteJump = false
    Settings.JumpHack = false
    Settings.Autofarm = false
    Settings.Autosell = false
    Settings.Platform = false
    
    -- Очищаем глобальные флаги
    _G.YBAEnhancedLoaded = false
    _G.YBAEnhancedCleanup = nil
    
    -- КРИТИЧНО: Очищаем ВСЕ _G переменные скрипта (НЕ трогаем настройки для автозапуска)
    _G.YBAAutoRestart = nil
    _G.YBAAutofarmThread = nil
    _G.YBAEnhancedReloaded = nil
    
    -- Очищаем локальные переменные
    isFlying = false
    isNoClipping = false
    isSpeedHacking = false
    isInfiniteJumping = false
    isJumpHacking = false
    isAutofarmEnabled = false
    isAutosellEnabled = false
    isAutobuyEnabled = false
    antiAFKEnabled = false
    cheaterDetectionEnabled = false
    
    -- Очищаем таблицы
    detectedCheaters = {}
    playerPositions = {}
    cheaterTimers = {}
    cheaterDetections = {}
    cheaterViewEnabled = false
    if cheaterViewThread then
        pcall(function() task.cancel(cheaterViewThread) end)
        cheaterViewThread = nil
    end
    if cheaterDetectionThread then
        pcall(function() task.cancel(cheaterDetectionThread) end)
        cheaterDetectionThread = nil
    end
    
    -- НЕ сбрасываем статистику фарма (она в _G)
    -- farmStats = {itemsCollected = 0, itemsSold = 0, startTime = tick(), moneyCollected = 0, moneySold = 0, serverHops = 0, prevItemsCollected = 0, prevItemsSold = 0, prevMoneyCollected = 0, prevMoneySold = 0}
    
    pcall(function()
        if Window and Window.Notify then
            Window:Notify({
                Title = "Script Removal",
                Content = "Script completely removed from session!",
                Duration = 3
            })
        end
    end)
    
    LogSuccess("Script cleanup completed successfully!")
end

