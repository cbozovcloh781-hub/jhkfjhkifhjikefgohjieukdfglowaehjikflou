local function GetPlayerMoney()
    local success, money = pcall(function()
        local moneyLabel = Player.PlayerGui:FindFirstChild("HUD")
        if moneyLabel then
            local main = moneyLabel:FindFirstChild("Main")
            if main then
                local dropMoney = main:FindFirstChild("DropMoney")
                if dropMoney then
                    local moneyText = dropMoney:FindFirstChild("Money")
                    if moneyText and moneyText.Text then
                        local cleanText = moneyText.Text:gsub("[$,]", "")
                        return tonumber(cleanText) or 0
                    end
                end
            end
        end
        
        local playerStats = Player:FindFirstChild("PlayerStats")
        if playerStats then
            local moneyValue = playerStats:FindFirstChild("Money")
            if moneyValue and moneyValue:IsA("NumberValue") then
                return moneyValue.Value or 0
            end
        end
        
        return 0
    end)
    
    if success then
        return money
    else
        return 0
    end
end

-- Server Hop Function
local function ServerHop()
    pcall(function()
        if Window and Window.Notify then
            Window:Notify({
                Title = "Server Swap",
                Content = "Searching for new server...",
                Duration = 3
            })
        end
    end)
    
    local TeleportService = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")
    
    _G.YBAAutoRestart = true
    _G.YBAAutoFarmEnabled = Settings.Autofarm
    _G.YBAAutoSellEnabled = Settings.Autosell
    
    if Options and Options.FarmItems and Options.FarmItems.Value then
        _G.YBAFarmItems = Options.FarmItems.Value
    else
        _G.YBAFarmItems = Settings.FarmItems
    end
    
    if Options and Options.SellItems and Options.SellItems.Value then
        _G.YBASellItems = Options.SellItems.Value
    else
        _G.YBASellItems = Settings.SellItems
    end
    
    _G.YBAAutoServerHop = Settings.AutoServerHop
    _G.YBAItemsCollected = farmStats.itemsCollected
    _G.YBAMoneyCollected = farmStats.moneyCollected
    _G.YBAItemsSold = farmStats.itemsSold
    _G.YBAMoneySold = farmStats.moneySold
    _G.YBAServerHops = (farmStats.serverHops or 0) + 1
    _G.YBAStartTime = farmStats.startTime
    
    -- Send stats to server before hop
    pcall(function()
        local money = GetPlayerMoney()
        local uptime = math.floor(tick() - farmStats.startTime)
        
        local totalItems = 0
        local sellableItems = 0
        local sellableValue = 0
        local luckyArrows = 0
        local luckyMasks = 0
        
        for _, item in pairs(Player.Backpack:GetChildren()) do
            if item:IsA("Tool") then
                totalItems = totalItems + 1
                
                if item.Name == "Lucky Arrow" then
                    luckyArrows = luckyArrows + 1
                elseif item.Name == "Lucky Stone Mask" then
                    luckyMasks = luckyMasks + 1
                end
                
                local itemPrice = itemPrices[item.Name] or 0
                if itemPrice > 0 and item.Name ~= "Lucky Arrow" and item.Name ~= "Lucky Stone Mask" then
                    sellableItems = sellableItems + 1
                    sellableValue = sellableValue + itemPrice
                end
            end
        end
        
        local swapData = {
            action = "server_hop",
            balance = money,
            uptime = uptime,
            items_collected = _G.YBAItemsCollected,
            items_sold = _G.YBAItemsSold,
            money_collected = _G.YBAMoneyCollected,
            money_sold = _G.YBAMoneySold,
            server_hops = _G.YBAServerHops,
            total_uptime = math.floor(tick() - _G.YBAStartTime),
            current_account = game.Players.LocalPlayer.Name,
            inventory_total = totalItems,
            inventory_sellable = sellableItems,
            inventory_sellable_value = sellableValue,
            lucky_arrows = luckyArrows,
            lucky_masks = luckyMasks,
            autofarm_status = Settings.Autofarm,
            autosell_status = Settings.Autosell,
            is_server_hop = true,
            start_time = _G.YBAStartTime
        }
        
        request({
            Url = "http://localhost:5000/api/server_hop",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(swapData)
        })
    end)
    
    -- Queue teleport for auto-load
    local queueteleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    
    if queueteleport then
        local scriptURL = "https://raw.githubusercontent.com/cbozovcloh781-hub/jhkfjhkifhjikefgohjieukdfglowaehjikflou/refs/heads/main/njkclashslnjkqadiqsdujlouijlqdnl_yba"
        queueteleport([[loadstring(game:HttpGet("]] .. scriptURL .. [["))()]])
        
        if Window and Window.Notify then
            Window:Notify({
                Title = "Auto-load",
                Content = "Script will load automatically after teleport!",
                Duration = 3
            })
        end
    else
        if Window and Window.Notify then
            Window:Notify({
                Title = "Warning",
                Content = "Use autoloader for auto-loading!",
                Duration = 5
            })
        end
    end
    
    -- Retry logic with automatic server search
    local maxRetries = 10
    local retryCount = 0
    local teleportSuccess = false
    
    while retryCount < maxRetries and not teleportSuccess do
        retryCount = retryCount + 1
        
        local success, result = pcall(function()
            local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"))
            
            if servers and servers.data then
                local currentServerId = game.JobId
                local availableServers = {}
                
                for _, server in pairs(servers.data) do
                    if type(server) == "table" and tonumber(server.playing) and tonumber(server.maxPlayers) and server.playing < server.maxPlayers and server.id ~= currentServerId then
                        table.insert(availableServers, 1, server.id)
                    end
                end
                
                if #availableServers > 0 then
                    local randomServer = availableServers[math.random(1, #availableServers)]
                    
                    local teleportOptions = Instance.new("TeleportOptions")
                    teleportOptions.ShouldReserveServer = false
                    
                    local teleportAttempt = 0
                    local teleportError = nil
                    
                    while teleportAttempt < 3 do
                        teleportAttempt = teleportAttempt + 1
                        
                        local teleportSuccess, teleportResult = pcall(function()
                            TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer, Player, nil, teleportOptions)
                        end)
                        
                        if teleportSuccess then
                            return true
                        else
                            teleportError = tostring(teleportResult)
                            
                            if teleportError:find("GameFull") or teleportError:find("full") then
                                if Window and Window.Notify then
                                    Window:Notify({
                                        Title = "Server Swap",
                                        Content = "Server is full! Attempt " .. retryCount .. "/" .. maxRetries,
                                        Duration = 2
                                    })
                                end
                                break
                            else
                                task.wait(1)
                            end
                        end
                    end
                    
                    if teleportError then
                        return false
                    end
                else
                    if Window and Window.Notify then
                        Window:Notify({
                            Title = "Error",
                            Content = "No available servers found",
                            Duration = 5
                        })
                    end
                    return false
                end
            end
        end)
        
        if success and result then
            teleportSuccess = true
            break
        else
            task.wait(2)
        end
    end
    
    if not teleportSuccess then
        if Window and Window.Notify then
            Window:Notify({
                Title = "Swap Error",
                Content = "Could not find available server in " .. maxRetries .. " attempts",
                Duration = 5
            })
        end
    end
end

-- Cheater Detection System
local function StartCheaterDetection()
    if cheaterDetectionEnabled then return end
    cheaterDetectionEnabled = true
    
    _G.YBAAutoServerHop = true
    
    -- Clear old warnings thread with enhanced logging
    task.spawn(function()
        while cheaterDetectionEnabled and Settings.AutoServerHop do
            local currentTime = tick()
            local warningTimeout = 60
            
            for userId, data in pairs(cheaterDetections) do
                if data.lastWarning and (currentTime - data.lastWarning) >= warningTimeout then
                    cheaterDetections[userId] = nil
                end
            end
            
            task.wait(10)
        end
    end)
    
    task.spawn(function()
        while cheaterDetectionEnabled and Settings.AutoServerHop do
            -- Enhanced AFK farmer detection at crane
            local craneBox = nil
            pcall(function()
                craneBox = workspace.Map.Prison.Prison_Props.Prison_Crane2.Prison_Crane1_CraneBox
            end)
            
            if craneBox then
                local afkFarmersCount = 0
                local afkFarmerNames = {}
                
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (player.Character.HumanoidRootPart.Position - craneBox.Position).Magnitude
                        
                        if distance < 20 then
                            afkFarmersCount = afkFarmersCount + 1
                            table.insert(afkFarmerNames, player.Name)
                        end
                    end
                end
                
                if afkFarmersCount >= 2 then
                    pcall(function()
                        if Window and Window.Notify then
                            Window:Notify({
                                Title = "Server Swap",
                                Content = "Detected " .. afkFarmersCount .. " AFK farmers! Changing server in 3 seconds...",
                                Duration = 3
                            })
                        end
                    end)
                    
                    task.wait(3)
                    ServerHop()
                    return
                end
            end
            
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local currentPos = player.Character.HumanoidRootPart.Position
                    
                    if playerPositions[player.UserId] then
                        local lastPos = playerPositions[player.UserId].Position
                        local lastTime = playerPositions[player.UserId].Time
                        local currentTime = tick()
                        
                        local distance = (currentPos - lastPos).Magnitude
                        local timeDiff = currentTime - lastTime
                        
                        if timeDiff > 0.5 and timeDiff < 2 then
                            local speed = distance / timeDiff
                            
                            if speed > 600 then
                                if not cheaterDetections[player.UserId] then
                                    cheaterDetections[player.UserId] = {count = 0, lastWarning = currentTime, firstDetection = currentTime}
                                end
                                
                                cheaterDetections[player.UserId].count = cheaterDetections[player.UserId].count + 1
                                cheaterDetections[player.UserId].lastWarning = currentTime
                                
                                local warningCount = cheaterDetections[player.UserId].count
                                
                                if warningCount >= Settings.CheaterDetectionSensitivity then
                                    detectedCheatersCount = detectedCheatersCount + 1
                                    detectedCheaters[player.UserId] = true
                                    
                                    pcall(function()
                                        if Window and Window.Notify then
                                            Window:Notify({
                                                Title = "Cheater Detected!",
                                                Content = player.Name .. " using teleport (" .. detectedCheatersCount .. "/3)",
                                                Duration = 5
                                            })
                                        end
                                    end)
                                    
                                    cheaterDetections[player.UserId].count = 0
                                    
                                    if detectedCheatersCount >= 3 then
                                        pcall(function()
                                            if Window and Window.Notify then
                                                Window:Notify({
                                                    Title = "Server Swap",
                                                    Content = "Detected 3 cheaters! Changing server in 3 seconds...",
                                                    Duration = 3
                                                })
                                            end
                                        end)
                                        
                                        task.wait(3)
                                        ServerHop()
                                        return
                                    end
                                end
                            end
                        end
                    end
                    
                    playerPositions[player.UserId] = {
                        Position = currentPos,
                        Time = tick()
                    }
                end
            end
            
            task.wait(0.5)
        end
    end)
end

